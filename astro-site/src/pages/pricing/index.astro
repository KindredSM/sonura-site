---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PricingSection from '../../components/PricingSection.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Sonura Pricing",
    "url": "https://sonurastudio.com/pricing/",
    "description": "Sonura pricing plans for AI music generation. Choose Starter, Pro, or Studio."
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sonurastudio.com/" },
      { "@type": "ListItem", "position": 2, "name": "Pricing", "item": "https://sonurastudio.com/pricing/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Sonura",
    "applicationCategory": "MusicApplication",
    "operatingSystem": "Web Browser",
    "offers": [
      { "@type": "Offer", "name": "Free", "price": "0", "priceCurrency": "USD", "description": "Free credits, no credit card required" },
      { "@type": "Offer", "name": "Starter", "price": "10", "priceCurrency": "USD", "billingIncrement": "P1M", "description": "200 creation credits/month: around 100 4-bar loops, 200 one-shots, or 25 full tracks" },
      { "@type": "Offer", "name": "Pro", "price": "20", "priceCurrency": "USD", "billingIncrement": "P1M", "description": "500 creation credits/month: around 250 4-bar loops, 500 one-shots, or 70 full tracks" },
      { "@type": "Offer", "name": "Studio", "price": "45", "priceCurrency": "USD", "billingIncrement": "P1M", "description": "1000 creation credits/month: around 500 4-bar loops, 1000 one-shots, or 140 full tracks" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is Sonura free?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Sonura offers free credits to get started with no credit card required. Check the current Terms if you plan to release or sell work created on the free tier." }
      },
      {
        "@type": "Question",
        "name": "Can I cancel anytime?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. All plans are month-to-month with no contracts. Cancel anytime from your account settings." }
      },
      {
        "@type": "Question",
        "name": "Do I own the music I create?",
        "acceptedAnswer": { "@type": "Answer", "text": "You retain ownership of Created Content you create with Sonura, subject to the Terms. Private content remains exclusively yours; content shared publicly is released under CC0." }
      },
      {
        "@type": "Question",
        "name": "What payment methods do you accept?",
        "acceptedAnswer": { "@type": "Answer", "text": "We accept all major credit cards, debit cards, and payment methods through our secure payment processor." }
      },
      {
        "@type": "Question",
        "name": "Is stem export included on all plans?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Stem export is available in Sonura for export-driven workflows. Check the current in-app plan details for free-tier availability." }
      }
    ]
  }
];
---

<BaseLayout
  title="Sonura Pricing | AI Music Generator Plans - Free, Starter, Pro, Studio"
  description="Sonura pricing for AI music generation. Pro is $20/month. No contracts, cancel anytime."
  keywords="sonura pricing, ai music generator pricing, ai beat maker pricing, sonura plans, sonura cost, ai music generator free, sonura free tier"
  canonical="https://sonurastudio.com/pricing/"
  ogTitle="Sonura Pricing - AI Music Generator Plans"
  ogDescription="Flexible plans for producers, artists, and creators. Pro is $20/month."
  jsonLd={jsonLd}
>
  <style>
    .pricing-page {
      margin: 0 0 clamp(72px, 9vw, 110px);
      padding: 0 var(--page-pad);
    }

    .pricing-page-title {
      font-family: var(--font-display);
      font-size: clamp(48px, 6.5vw, 92px);
      font-weight: 400;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      line-height: 1;
      text-align: left;
      color: var(--fg);
      margin: 0 0 20px;
      max-width: none;
    }

    .pricing-page-sub {
      text-align: left;
      color: var(--muted);
      font-size: 17px;
      line-height: 1.8;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      text-transform: lowercase;
      max-width: 560px;
      margin: 0 0 8px;
    }

    .pricing-page-header {
      padding-top: clamp(56px, 9vh, 96px);
    }

    .compare-section {
      max-width: none;
      margin: clamp(72px, 9vw, 110px) 0 0;
      overflow-x: auto;
    }

    .compare-title,
    .pricing-faq-title {
      font-family: var(--font-display);
      font-size: clamp(38px, 4.8vw, 68px);
      font-weight: 400;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      line-height: 1;
      text-align: left;
      color: var(--fg);
      margin: 0 0 16px;
    }

    .compare-sub {
      text-align: left;
      color: var(--muted);
      font-size: 16px;
      line-height: 1.8;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      text-transform: lowercase;
      margin: 0 0 32px;
    }

    .compare-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 48px;
    }

    .compare-table th, .compare-table td {
      padding: 16px 20px;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    .compare-table th {
      font-weight: 600;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
    }

    .compare-table td { font-size: 15px; color: var(--muted); }
    .compare-table td:first-child { color: var(--fg); }
    .compare-table td:not(:first-child) { text-align: center; }
    .compare-table th:not(:first-child) { text-align: center; }

    .pricing-faq {
      max-width: none;
      margin: clamp(72px, 9vw, 110px) 0 0;
    }

    .pricing-faq-title { margin-bottom: 40px; }

    .pricing-faq details {
      border-top: 1px solid var(--hairline);
      border-radius: var(--radius-panel);
      background: transparent;
      padding: 0;
      margin: 0;
      cursor: pointer;
    }

    .pricing-faq details:last-child {
      border-bottom: 1px solid var(--hairline);
    }

    .pricing-faq summary {
      font-weight: 600;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--fg);
      padding: 22px 0;
    }

    .pricing-faq details p {
      color: var(--muted);
      line-height: 1.8;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      text-transform: lowercase;
      max-width: 760px;
      margin: 0;
      padding: 0 0 24px;
    }

    @media (max-width: 768px) {
      .compare-table {
        font-size: 13px;
      }

      .compare-table th, .compare-table td {
        padding: 10px 8px;
      }
    }
  </style>

  <div class="pricing-page">
    <header class="pricing-page-header">
      <p class="section-kicker">01 / Plans</p>
      <h1 class="pricing-page-title">Sonura plans &amp; pricing</h1>
      <p class="pricing-page-sub">Start free. Upgrade when you're ready. Full commercial rights on every plan.</p>
    </header>
    <PricingSection showHeader={true} showTrust={false} showSecureBadge={true} />

    <div class="compare-section">
      <p class="section-kicker">02 / Compare</p>
      <h2 class="compare-title">Compare Plans</h2>
      <p class="compare-sub">All plans include commercial rights and stem export.</p>
      <table class="compare-table">
        <thead>
          <tr>
            <th>Feature</th>
            <th>Starter</th>
            <th>Pro</th>
            <th>Studio</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Credits</td><td>200/mo</td><td>500/mo</td><td>1000/mo</td></tr>
          <tr><td>Commercial Rights</td><td>Yes</td><td>Yes</td><td>Yes</td></tr>
          <tr><td>Stem Export</td><td>Yes</td><td>Yes</td><td>Yes</td></tr>
          <tr><td>Smart Mixing</td><td>Yes</td><td>Yes</td><td>Yes</td></tr>
          <tr><td>Download Quality</td><td>High Quality</td><td>High Quality</td><td>High Quality</td></tr>
          <tr><td>24/7 Support</td><td>-</td><td>Yes</td><td>Yes</td></tr>
          <tr><td>Early Access</td><td>-</td><td>Yes</td><td>Yes</td></tr>
          <tr><td>1-on-1 Support Calls</td><td>-</td><td>-</td><td>Yes</td></tr>
          <tr><td>Custom Features</td><td>-</td><td>-</td><td>Yes</td></tr>
        </tbody>
      </table>
    </div>

    <section class="pricing-faq">
      <p class="section-kicker">03 / FAQ</p>
      <h2 class="pricing-faq-title">Pricing FAQ</h2>
      <div>
        <details>
          <summary>Is Sonura really free to start?</summary>
          <p>Yes. Sign up with no credit card and get free credits to create beats, loops, vocals, and more. If you plan to release or sell work created on the free tier, check the current Terms so you understand public and private content rules.</p>
        </details>
        <details>
          <summary>Can I cancel anytime?</summary>
          <p>Yes. All plans are month-to-month with no contracts or commitments. Cancel from your account settings at any time.</p>
        </details>
        <details>
          <summary>Do I own the music I create?</summary>
          <p>You retain ownership of Created Content you create with Sonura, subject to the Terms. Private content remains exclusively yours; content shared publicly is released under CC0 so others can use and remix it too.</p>
        </details>
        <details>
          <summary>Is stem export included on all plans?</summary>
          <p>Yes. Stem export is available in Sonura for export-driven workflows. Check the current in-app plan details for free-tier availability.</p>
        </details>
        <details>
          <summary>What payment methods do you accept?</summary>
          <p>We accept all major credit cards and debit cards through our secure payment processor.</p>
        </details>
        <details>
          <summary>How does Sonura pricing compare to competitors?</summary>
          <p>Sonura is priced around producer workflows: credits for creation, high-quality downloads, stem export, and commercial-ready creation. Pro is $20/month with no contracts.</p>
        </details>
      </div>
    </section>

  </div>
</BaseLayout>
