---
import BaseLayout from '../../layouts/BaseLayout.astro';

const useCases = [
  {
    name: 'YouTube Music',
    slug: 'youtube-music',
    description: 'Royalty-free background music for videos. No copyright claims, full commercial rights.',
    audience: 'Content Creators'
  },
  {
    name: 'Type Beats',
    slug: 'type-beats',
    description: 'Create type beats to sell on BeatStars and Airbit. Full commercial rights, stem export.',
    audience: 'Beat Producers'
  },
  {
    name: 'For Vocalists',
    slug: 'vocalists',
    description: 'Custom backing tracks and instrumentals for practice, demos, and performances. Any genre, key, and tempo.',
    audience: 'Vocalists & Singers'
  },
  {
    name: 'For Songwriters',
    slug: 'songwriters',
    description: 'Beat writer\'s block with instant instrumentals. Demo songs in minutes. Full publishing rights included.',
    audience: 'Songwriters'
  },
  {
    name: 'For Composers',
    slug: 'composers',
    description: 'Sketch musical ideas instantly. Create orchestral textures, atmospheric beds, and reference tracks.',
    audience: 'Composers'
  },
  {
    name: 'For Video Editors',
    slug: 'video-editors',
    description: 'Royalty-free background music, transitions, and SFX for edits. Works with Premiere, Final Cut, DaVinci.',
    audience: 'Video Editors'
  },
  {
    name: 'For Artists',
    slug: 'music-artists',
    description: 'Create custom beats and release music faster. Full ownership, no producer splits, no restrictions.',
    audience: 'Independent Artists'
  },
  {
    name: 'Podcast Music',
    slug: 'podcast-music',
    description: 'Custom intros, outros, and background music for podcasts. Unique branding sounds.',
    audience: 'Podcasters'
  },
  {
    name: 'Game Music',
    slug: 'game-music',
    description: 'Adaptive soundtracks and ambient music for games. Loops and stems for implementation.',
    audience: 'Game Developers'
  },
  {
    name: 'Film Scoring',
    slug: 'film-scoring',
    description: 'Cinematic music and scores for video projects. Atmospheric and dramatic compositions.',
    audience: 'Film Makers'
  },
  {
    name: 'AI Vocals',
    slug: 'ai-vocals',
    description: 'Create vocal chops, ad-libs, hooks, and samples. Add professional vocal elements to your tracks.',
    audience: 'Music Producers'
  },
  {
    name: 'Sample Packs',
    slug: 'sample-packs',
    description: 'Create unique sample packs with original sounds. Stand out from generic libraries.',
    audience: 'Sample Creators'
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Sonura Use Cases",
    "description": "Discover how creators use Sonura for YouTube music, type beats, podcasts, games, and more.",
    "url": "https://sonurastudio.com/use-cases/"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sonurastudio.com/" },
      { "@type": "ListItem", "position": 2, "name": "Use Cases", "item": "https://sonurastudio.com/use-cases/" }
    ]
  }
];
---

<BaseLayout
  title="AI Music Use Cases | YouTube, Type Beats, Podcasts & More - Sonura"
  description="Discover how creators use Sonura for YouTube music, type beats, podcast audio, game soundtracks, and film scoring. Real use cases for AI music generation."
  keywords="ai music use cases, youtube music generator, type beat maker, podcast music, game music ai, film score generator, content creator music"
  canonical="https://sonurastudio.com/use-cases/"
  ogTitle="Sonura Use Cases"
  ogDescription="Discover how creators use Sonura for YouTube, type beats, podcasts, games, and more."
  jsonLd={jsonLd}
>
  <style>
    .usecases-hub {
      padding: clamp(56px, 9vh, 110px) var(--page-pad) clamp(96px, 12vw, 140px);
    }

    .hub-header {
      margin-bottom: clamp(48px, 7vw, 80px);
    }

    .hub-title {
      margin: 0 0 24px;
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(48px, 7vw, 104px);
      line-height: 0.98;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--fg);
    }

    .hub-sub {
      margin: 0;
      max-width: 620px;
      font-size: 17px;
      color: var(--muted);
      text-transform: lowercase;
      letter-spacing: 0.022em;
      line-height: 1.8;
      word-spacing: 0.04em;
    }

    .usecase-hub-grid {
      display: flex;
      flex-direction: column;
      border-bottom: 1px solid var(--hairline);
    }

    .usecase-card {
      display: grid;
      grid-template-columns: 44px 160px minmax(180px, 260px) 1fr auto;
      align-items: baseline;
      gap: 24px;
      padding: 28px 0;
      border-top: 1px solid var(--hairline);
      background: transparent;
      text-decoration: none;
      color: inherit;
      position: relative;
      transition: color 0.2s;
    }

    .usecase-card-index {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.12em;
      font-variant-numeric: tabular-nums;
      color: var(--faint);
    }

    .usecase-card-audience {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--primary);
    }

    .usecase-card-name {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(20px, 2.2vw, 28px);
      line-height: 1;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--fg);
    }

    .usecase-card-desc {
      margin: 0;
      max-width: 560px;
      color: var(--muted);
      font-size: 15px;
      text-transform: lowercase;
      letter-spacing: 0.022em;
      line-height: 1.8;
      word-spacing: 0.04em;
    }

    .usecase-card-arrow {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      transition: color 0.2s;
    }

    .usecase-card:hover .usecase-card-arrow {
      color: var(--fg);
    }

    .hub-cta {
      margin-top: clamp(72px, 9vw, 110px);
      padding: clamp(40px, 6vw, 72px);
      background: transparent;
      border: 1px solid var(--hairline);
      border-radius: var(--radius-panel);
    }

    .hub-cta-title {
      margin: 0 0 20px;
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(34px, 4.4vw, 56px);
      line-height: 1;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--fg);
    }

    .hub-cta-sub {
      margin: 0 0 32px;
      max-width: 560px;
      color: var(--muted);
      font-size: 15px;
      text-transform: lowercase;
      letter-spacing: 0.022em;
      line-height: 1.8;
      word-spacing: 0.04em;
    }

    .hub-cta .button.primary {
      display: inline-block;
      padding: 20px 36px;
      background: var(--fg);
      color: var(--bg);
      border: 1px solid var(--fg);
      border-radius: var(--radius-ui);
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .hub-cta .button.primary:hover {
      background: var(--fg);
      color: var(--bg);
      transform: none;
    }

    @media (max-width: 900px) {
      .usecase-card {
        display: block;
        padding: 24px 0;
      }

      .usecase-card-index {
        display: inline-block;
        margin-right: 16px;
        margin-bottom: 12px;
      }

      .usecase-card-audience {
        display: inline-block;
        margin-bottom: 12px;
      }

      .usecase-card-name {
        margin-bottom: 10px;
      }

      .usecase-card-arrow {
        display: inline-block;
        margin-top: 14px;
      }
    }
  </style>

  <div class="usecases-hub">
    <header class="hub-header">
      <p class="section-kicker">01 / Use cases</p>
      <h1 class="hub-title">Use Cases</h1>
      <p class="hub-sub">Discover how creators, producers, and businesses use Sonura to create music for their projects.</p>
    </header>

    <div class="usecase-hub-grid">
      {useCases.map((useCase, index) => (
        <a href={`/use-cases/${useCase.slug}/`} class="usecase-card">
          <span class="usecase-card-index">{String(index + 1).padStart(2, '0')}</span>
          <div class="usecase-card-audience">{useCase.audience}</div>
          <div class="usecase-card-name">{useCase.name}</div>
          <p class="usecase-card-desc">{useCase.description}</p>
          <div class="usecase-card-arrow">Learn more →</div>
        </a>
      ))}
    </div>

    <div class="hub-cta">
      <p class="section-kicker">02 / Get started</p>
      <h2 class="hub-cta-title">Have a Different Use Case?</h2>
      <p class="hub-cta-sub">Sonura works for any project that needs music. Try it free and see what you can create.</p>
      <a href="https://app.sonurastudio.com/studio" class="button primary large"><span class="btn-label-full">Start Creating Free</span><span class="btn-label-short">Start free</span></a>
    </div>
  </div>
</BaseLayout>

