---
import BaseLayout from '../../layouts/BaseLayout.astro';

const alternatives = [
  {
    name: 'Suno',
    slug: 'suno-alternative',
    description: 'Looking for faster beat creation and stem export? Sonura delivers 10x faster output with producer-focused features.',
    comparison: 'Best for: Beats, loops & vocals vs full songs with AI singing'
  },
  {
    name: 'Udio',
    slug: 'udio-alternative',
    description: 'Need beats, loops, and vocals instead of full songs? Sonura is built for producers who want fast, professional creation.',
    comparison: 'Best for: Beat production vs experimental full songs'
  },
  {
    name: 'Soundraw',
    slug: 'soundraw-alternative',
    description: 'Want true AI creation instead of templates? Sonura creates unique music from text prompts, not preset combinations.',
    comparison: 'Best for: Unique AI creation vs template customization'
  },
  {
    name: 'Boomy',
    slug: 'boomy-alternative',
    description: 'Need professional quality with stem export? Sonura delivers studio-grade output with full production control.',
    comparison: 'Best for: Professional production vs beginner-friendly'
  },
  {
    name: 'AIVA',
    slug: 'aiva-alternative',
    description: 'Making beats instead of classical? Sonura excels at modern genres - trap, hip-hop, house, drill, and more.',
    comparison: 'Best for: Modern beats vs classical/orchestral'
  },
  {
    name: 'Mubert',
    slug: 'mubert-alternative',
    description: 'Need discrete tracks instead of streams? Sonura creates downloadable beats with full stem export.',
    comparison: 'Best for: Production tracks vs continuous streams'
  },
  {
    name: 'Splice',
    slug: 'splice-alternative',
    description: 'Want unique AI-created samples instead of shared libraries? Sonura creates original samples on-demand in seconds.',
    comparison: 'Best for: Unique AI samples vs browsing shared libraries'
  },
  {
    name: 'Beatoven.ai',
    slug: 'beatoven-alternative',
    description: 'Need more than background music? Sonura creates beats, loops, vocals, and one-shots with stem export on all tiers.',
    comparison: 'Best for: Full production vs background music only'
  },
  {
    name: 'Loudly',
    slug: 'loudly-alternative',
    description: 'Want commercial rights on the free tier? Sonura offers full rights, stem export, and more music types from day one.',
    comparison: 'Best for: Producer tools vs social media background music'
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "AI Music Generator Alternatives",
    "description": "Compare Sonura with other AI music generators and music creation tools. Find the best alternative to Suno, Udio, Soundraw, Boomy, AIVA, Mubert, and Splice.",
    "url": "https://sonurastudio.com/alternatives/"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sonurastudio.com/" },
      { "@type": "ListItem", "position": 2, "name": "Alternatives", "item": "https://sonurastudio.com/alternatives/" }
    ]
  }
];
---

<BaseLayout
  title="AI Music Generator Alternatives | Compare Sonura vs Competitors"
  description="Compare Sonura with other AI music generators and music creation tools. Find the best alternative for beats, loops, samples, vocals, and full tracks."
  keywords="ai music generator alternatives, suno alternative, udio alternative, soundraw alternative, boomy alternative, aiva alternative, mubert alternative, splice alternative, beatoven alternative, loudly alternative, best ai music generator"
  canonical="https://sonurastudio.com/alternatives/"
  ogTitle="AI Music Generator Alternatives"
  ogDescription="Compare Sonura with other AI music generators and find the best tool for your needs."
  jsonLd={jsonLd}
>
  <style>
    .alt-hub {
      width: 100%;
      padding: clamp(56px, 9vh, 110px) var(--page-pad) clamp(96px, 12vw, 140px);
      color: var(--fg);
    }

    .alt-hub-header {
      margin-bottom: clamp(56px, 8vw, 96px);
    }

    .alt-hub-header h1 {
      margin: 0 0 28px;
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(44px, 6.6vw, 100px);
      line-height: 0.98;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--fg);
    }

    .alt-hub-header p {
      margin: 0;
      max-width: 640px;
      font-size: 16px;
      color: var(--muted);
      text-transform: lowercase;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      line-height: 1.8;
    }

    .alt-hub-list {
      border-bottom: 1px solid var(--hairline);
    }

    .alt-row {
      display: grid;
      grid-template-columns: 64px minmax(0, 0.9fr) minmax(0, 1.3fr);
      gap: 24px 40px;
      align-items: baseline;
      padding: 32px 0;
      border-top: 1px solid var(--hairline);
      text-decoration: none;
      color: inherit;
    }

    .alt-row-index {
      font-size: 13px;
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.12em;
      color: var(--faint);
    }

    .alt-card-name {
      margin: 0;
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(22px, 2.6vw, 34px);
      line-height: 1;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--fg);
    }

    .alt-row-body {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .alt-card-desc {
      margin: 0;
      color: var(--muted);
      font-size: 15px;
      text-transform: lowercase;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      line-height: 1.8;
    }

    .alt-card-comparison {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--faint);
    }

    .alt-card-arrow {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .alt-row:hover .alt-card-arrow,
    .alt-row:hover .alt-card-name {
      color: var(--fg);
    }

    .alt-row:hover .alt-card-arrow {
      text-decoration: underline;
      text-underline-offset: 7px;
    }

    .alt-hub-cta {
      margin-top: clamp(72px, 9vw, 110px);
      padding: clamp(40px, 6vw, 72px) clamp(28px, 4vw, 64px);
      border: 1px solid var(--hairline);
    }

    .alt-hub-cta h2 {
      margin: 0 0 20px;
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(32px, 4.8vw, 64px);
      line-height: 1;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--fg);
    }

    .alt-hub-cta p {
      margin: 0 0 36px;
      max-width: 560px;
      color: var(--muted);
      font-size: 15px;
      text-transform: lowercase;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      line-height: 1.8;
    }

    .alt-hub-cta .button.primary {
      display: inline-block;
    }

    @media (max-width: 860px) {
      .alt-row {
        grid-template-columns: 48px minmax(0, 1fr);
        gap: 12px 20px;
      }

      .alt-row-body {
        grid-column: 2;
      }
    }
  </style>

  <div class="alt-hub">
    <header class="alt-hub-header">
      <p class="section-kicker">01 / Compare</p>
      <h1>AI Music Generator Alternatives</h1>
      <p>Compare Sonura with other AI music generators and music creation tools. Find out which tool is best for your specific needs - beats, loops, samples, or more.</p>
    </header>

    <div class="alt-hub-list">
      {alternatives.map((alt, i) => (
        <a href={`/alternatives/${alt.slug}/`} class="alt-row">
          <span class="alt-row-index">{String(i + 1).padStart(2, '0')}</span>
          <div class="alt-card-name">{alt.name} Alternative</div>
          <div class="alt-row-body">
            <p class="alt-card-desc">{alt.description}</p>
            <div class="alt-card-comparison">{alt.comparison}</div>
            <div class="alt-card-arrow">Compare Sonura vs {alt.name} →</div>
          </div>
        </a>
      ))}
    </div>

    <div class="alt-hub-cta">
      <p class="section-kicker">02 / Get started</p>
      <h2>Not Sure Which to Choose?</h2>
      <p>Try Sonura free and see if it fits your workflow. No credit card required, full features available.</p>
      <a href="https://app.sonurastudio.com/" class="button primary large">Try Sonura Free</a>
    </div>
  </div>
</BaseLayout>
