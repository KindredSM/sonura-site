---
import BaseLayout from '../../layouts/BaseLayout.astro';

type Feature = {
  name: string;
  slug: string;
  description: string;
  icon: string;
  comingSoon?: boolean;
};

const features: Feature[] = [
  {
    name: 'AI Vocals',
    slug: 'ai-vocals',
    description: 'Create vocal chops, samples, ad-libs, and hooks. Add professional vocal elements to your productions.',
    icon: 'mic'
  },
  {
    name: 'AI Loops',
    slug: 'ai-loops',
    description: 'Create perfectly loopable drum, melody, and bass loops. Seamless for DAW workflows.',
    icon: 'repeat'
  },
  {
    name: 'AI Beats',
    slug: 'ai-beats',
    description: 'Create complete beats with drums, bass, and melody. Any genre in under 10 seconds.',
    icon: 'music'
  },
  {
    name: 'Stem Export',
    slug: 'stem-export',
    description: 'Export individual stems for mixing. Drums, bass, melody, FX - all separately.',
    icon: 'layers'
  },
  {
    name: 'Text to Music',
    slug: 'text-to-music',
    description: 'Describe what you want in natural language. The AI understands production terminology.',
    icon: 'type'
  },
  {
    name: 'AI Sound Effects',
    slug: 'ai-sound-effects',
    description: 'Create risers, drops, impacts, and atmospheric FX. Custom sound design.',
    icon: 'zap'
  },
  {
    name: 'One-Shots',
    slug: 'one-shots',
    description: 'Create unique drum and melodic one-shots. Build custom sample packs.',
    icon: 'circle'
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Sonura Features",
    "description": "Explore Sonura music generation features: vocals, loops, beats, stems, and more.",
    "url": "https://sonurastudio.com/features/"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sonurastudio.com/" },
      { "@type": "ListItem", "position": 2, "name": "Features", "item": "https://sonurastudio.com/features/" }
    ]
  }
];
---

<BaseLayout
  title="AI Music Generation Features | Vocals, Loops, Beats & More - Sonura"
  description="Explore Sonura's AI music generation features: AI vocals, loops, beats, stem export, text-to-music, and sound effects. Everything you need for music production."
  keywords="ai music features, ai vocals, ai loops, ai beats, stem export, text to music, ai sound effects, music generation features"
  canonical="https://sonurastudio.com/features/"
  ogTitle="Sonura Features"
  ogDescription="Explore all AI music generation features: vocals, loops, beats, stems, and more."
  jsonLd={jsonLd}
>
  <style>
    .features-hub {
      padding: clamp(56px, 9vh, 110px) var(--page-pad) clamp(96px, 12vw, 140px);
    }

    .hub-header {
      margin-bottom: clamp(48px, 7vw, 80px);
    }

    .hub-title {
      margin: 0 0 24px;
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(48px, 7vw, 104px);
      line-height: 0.98;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--fg);
    }

    .hub-sub {
      margin: 0;
      max-width: 620px;
      font-size: 17px;
      color: var(--muted);
      text-transform: lowercase;
      letter-spacing: 0.022em;
      line-height: 1.8;
      word-spacing: 0.04em;
    }

    .hub-tools-link {
      margin: 24px 0 0;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .hub-tools-link a {
      color: var(--fg);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 7px;
      text-decoration-color: currentColor;
    }

    .feature-hub-grid {
      display: flex;
      flex-direction: column;
      border-bottom: 1px solid var(--hairline);
    }

    .feature-card {
      display: grid;
      grid-template-columns: 44px 32px minmax(180px, 280px) 1fr auto;
      align-items: baseline;
      gap: 24px;
      padding: 28px 0;
      border-top: 1px solid var(--hairline);
      background: transparent;
      text-decoration: none;
      color: inherit;
      position: relative;
      transition: color 0.2s;
    }

    .feature-card-index {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.12em;
      font-variant-numeric: tabular-nums;
      color: var(--faint);
    }

    .feature-card-icon {
      width: 24px;
      height: 24px;
      background: transparent;
      border-radius: var(--radius-ui);
      display: flex;
      align-items: center;
      justify-content: center;
      align-self: center;
      color: var(--faint);
    }

    .feature-card-name {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(20px, 2.2vw, 28px);
      line-height: 1;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--fg);
    }

    .feature-card-desc {
      margin: 0;
      max-width: 560px;
      color: var(--muted);
      font-size: 15px;
      text-transform: lowercase;
      letter-spacing: 0.022em;
      line-height: 1.8;
      word-spacing: 0.04em;
    }

    .feature-card-arrow {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      transition: color 0.2s;
    }

    .feature-card:hover .feature-card-arrow {
      color: var(--fg);
    }

    .coming-soon-badge {
      position: absolute;
      top: 28px;
      right: 0;
      font-size: 11px;
      font-weight: 500;
      padding: 4px 10px;
      background: transparent;
      border: 1px solid var(--border-light);
      border-radius: var(--radius-ui);
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .feature-card.coming-soon {
      opacity: 0.7;
      pointer-events: none;
    }

    .hub-cta {
      margin-top: clamp(72px, 9vw, 110px);
      padding: clamp(40px, 6vw, 72px);
      background: transparent;
      border: 1px solid var(--hairline);
      border-radius: var(--radius-panel);
    }

    .hub-cta-title {
      margin: 0 0 20px;
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(34px, 4.4vw, 56px);
      line-height: 1;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--fg);
    }

    .hub-cta-sub {
      margin: 0 0 32px;
      max-width: 560px;
      color: var(--muted);
      font-size: 15px;
      text-transform: lowercase;
      letter-spacing: 0.022em;
      line-height: 1.8;
      word-spacing: 0.04em;
    }

    .hub-cta .button.primary {
      display: inline-block;
      padding: 20px 36px;
      background: var(--fg);
      color: var(--bg);
      border: 1px solid var(--fg);
      border-radius: var(--radius-ui);
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .hub-cta .button.primary:hover {
      background: var(--fg);
      color: var(--bg);
      transform: none;
    }

    @media (max-width: 900px) {
      .feature-card {
        display: block;
        padding: 24px 0;
      }

      .feature-card-index {
        display: inline-block;
        margin-bottom: 12px;
      }

      .feature-card-icon {
        display: none;
      }

      .feature-card-name {
        margin-bottom: 10px;
      }

      .feature-card-arrow {
        display: inline-block;
        margin-top: 14px;
      }
    }
  </style>

  <div class="features-hub">
    <header class="hub-header">
      <p class="section-kicker">01 / Features</p>
      <h1 class="hub-title">Sonura Features</h1>
      <p class="hub-sub">Everything you need to create professional music with AI. From vocals to full beats, loops to stems.</p>
      <p class="hub-tools-link"><a href="/tools/">Browse free AI music tool pages →</a></p>
    </header>

    <div class="feature-hub-grid">
      {features.map((feature, index) => (
        <a href={feature.comingSoon ? '#' : `/features/${feature.slug}/`} class={`feature-card ${feature.comingSoon ? 'coming-soon' : ''}`}>
          {feature.comingSoon && <span class="coming-soon-badge">Coming Soon</span>}
          <span class="feature-card-index">{String(index + 1).padStart(2, '0')}</span>
          <div class="feature-card-icon">
            <i data-lucide={feature.icon}></i>
          </div>
          <div class="feature-card-name">{feature.name}</div>
          <p class="feature-card-desc">{feature.description}</p>
          {!feature.comingSoon && <div class="feature-card-arrow">Learn more →</div>}
        </a>
      ))}
    </div>

    <div class="hub-cta">
      <p class="section-kicker">02 / Get started</p>
      <h2 class="hub-cta-title">Try All Features Free</h2>
      <p class="hub-cta-sub">No credit card required. Full access to all features on the free tier.</p>
      <a href="https://app.sonurastudio.com/studio" class="button primary large"><span class="btn-label-full">Start Creating Free</span><span class="btn-label-short">Start free</span></a>
    </div>
  </div>
</BaseLayout>
