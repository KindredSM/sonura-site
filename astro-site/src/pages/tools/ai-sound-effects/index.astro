---
import ToolLayout from '../../../layouts/ToolLayout.astro';

const features = [
  { title: 'Describe any sound', description: 'Impact, whoosh, UI blip, ambient bed, riser, foley hit. Write what you need and get audio back.' },
  { title: 'Production-ready output', description: 'Clean and usable out of the box. Drop directly into your timeline or process further.' },
  { title: 'Every category', description: 'Transitions, risers, drops, cinematic booms, sci-fi textures, UI feedback, and ambient beds.' },
  { title: 'Skip the library', description: 'Describe exactly what you need instead of browsing thousands of files in generic SFX packs.' },
  { title: 'Rapid iteration', description: 'Not right? Adjust the prompt and regenerate until the sound fits your picture or track.' },
  { title: 'Export and use', description: 'Download and place in your DAW, video editor, game engine, or podcast workflow.' },
];

const howItWorksSteps = [
  'Describe the sound: impact, whoosh, UI blip, ambient bed, or foley-style hit.',
  'Sonura generates short SFX tailored to your description.',
  'Export and place in your DAW, game engine, or video editor.',
];

const useCases = [
  { title: 'Video editors', description: 'Transitions, impacts, and ambient beds without scrolling through endless sound libraries.' },
  { title: 'Game developers', description: 'UI feedback, one-shot events, and environmental audio for prototypes and shipping builds.' },
  { title: 'Music producers', description: 'Risers, drops, ear candy, and textural elements between sections of a track.' },
  { title: 'Podcasters', description: 'Stingers, intro sounds, and short beds that match your show tone.' },
];

const faqs = [
  { question: 'What kind of sounds can I make?', answer: 'Transitions, UI blips, impacts, whooshes, risers, ambient beds, foley-style hits, and more. Describe it in text.' },
  { question: 'Can I use these in commercial projects?', answer: 'Review Sonura licensing for your plan before shipping assets in products or client work.' },
  { question: 'How long are generated sounds?', answer: 'Most SFX are a few seconds by design. Longer ambiences can be built from multiple generations.' },
  { question: 'What formats can I export?', answer: 'Export options depend on your Sonura plan. Check the app for available formats and quality settings.' },
];

const relatedTools = [
  { title: 'Sample Generator', href: '/tools/ai-sample-generator/', description: 'Musical one-shots and sample material.' },
  { title: 'Text to Music', href: '/tools/text-to-music/', description: 'Full musical ideas from a text prompt.' },
  { title: 'Melody Maker', href: '/tools/ai-melody-maker/', description: 'Tonal hooks and melodic lines.' },
];

const relatedBlogPosts = [
  { title: 'Best free VST plugins', href: '/blog/best-free-vst-plugins/' },
];
---

<ToolLayout
  toolName="Sound Effects Generator"
  toolSlug="ai-sound-effects"
  title="Sound Effects Generator | Create SFX Online Free - Sonura"
  description="Generate sound effects from text: whooshes, impacts, UI sounds, risers, and ambient beds in Sonura. Free to start."
  keywords="sound effects generator, sfx generator, create sound effects online, foley generator, free sfx maker"
  headline="Generate sound effects from a description"
  subhead="Whooshes, impacts, risers, UI blips, ambient beds, foley hits. Describe the sound you need and get audio back. No library subscriptions."
  features={features}
  howItWorksTitle="How it works"
  howItWorksSteps={howItWorksSteps}
  useCases={useCases}
  faqs={faqs}
  appUrl="https://app.sonurastudio.com/samples"
  ctaPrimaryText="Generate SFX free"
  finalCtaTitle="Create sound effects"
  finalCtaButtonText="Try it free"
  relatedTools={relatedTools}
  relatedBlogPosts={relatedBlogPosts}
/>
