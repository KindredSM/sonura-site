        <a class="button primary large" href="https://app.sonurastudio.com/">Get Started Free</a>
      </div>
      <div class="final-cta-trust reveal" data-reveal-delay="0.18s">
        <div class="trust-item"><span>Cancel anytime</span></div>
        <div class="trust-item"><span>Full commercial rights</span></div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const rows = Array.from(document.querySelectorAll<HTMLElement>('.demo-track'));
  const player = new Audio();
  // In the DOM with .player-audio so script.js's pauseAllPlayers() stops it
  // (e.g. when the creator-video modal opens)
  player.className = 'player-audio';
  player.hidden = true;
  document.body.appendChild(player);
  let activeRow: HTMLElement | null = null;

  const fmt = (s: number) => {
    if (!isFinite(s)) return '0:00';
    const m = Math.floor(s / 60);
    const r = Math.floor(s % 60);
    return `${m}:${String(r).padStart(2, '0')}`;
  };

  const paint = () => {
    if (!activeRow) return;
    const played = activeRow.querySelector<HTMLElement>('.demo-wave-played');
    const time = activeRow.querySelector<HTMLElement>('.demo-track-time');
    const pct = isFinite(player.duration) && player.duration > 0
      ? (player.currentTime / player.duration) * 100
      : 0;
    if (played) played.style.clipPath = `inset(0 ${Math.max(0, 100 - pct)}% 0 0)`;
    if (time) time.textContent = fmt(player.currentTime);
  };

  const resetRow = (row: HTMLElement) => {
    row.classList.remove('is-playing');
    const played = row.querySelector<HTMLElement>('.demo-wave-played');
    const time = row.querySelector<HTMLElement>('.demo-track-time');
    if (played) played.style.clipPath = 'inset(0 100% 0 0)';
    if (time) time.textContent = time.dataset.duration || '0:00';
  };

  rows.forEach((row) => {
    const button = row.querySelector<HTMLButtonElement>('.demo-play');
    const src = button?.dataset.demoAudio;
    if (!button || !src) return;

    button.addEventListener('click', () => {
      if (activeRow === row && !player.paused) {
        player.pause();
        return;
      }
      if (activeRow && activeRow !== row) resetRow(activeRow);
      if (activeRow !== row) {
        player.src = src;
        activeRow = row;
      }
      player.play().catch(() => {
        if (activeRow === row) resetRow(row);
      });
    });

    row.querySelector('.demo-track-progress')?.addEventListener('click', (event) => {
      if (activeRow !== row || !isFinite(player.duration)) return;
      const bar = event.currentTarget as HTMLElement;
      const rect = bar.getBoundingClientRect();
      const ratio = ((event as MouseEvent).clientX - rect.left) / rect.width;
      player.currentTime = Math.max(0, Math.min(1, ratio)) * player.duration;
      paint(); // repaint immediately so seeks are visible while paused/ended
    });
  });

  // Preview-type toggle (Loops / Songs). Audio keeps playing across tab
  // switches — the player is global, so a hidden row just keeps its progress.
  const tabButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-demo-tab]'));
  const tabGroups = Array.from(document.querySelectorAll<HTMLElement>('[data-demo-group]'));
  tabButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const id = button.dataset.demoTab;
      tabButtons.forEach((b) => b.setAttribute('aria-selected', String(b === button)));
      tabGroups.forEach((group) => { group.hidden = group.dataset.demoGroup !== id; });
    });
  });

  // Smooth 60fps progress: keep the loop alive even before metadata loads
  // (paint() guards against NaN duration until it arrives)
  let rafId = 0;
  const tick = () => {
    if (!activeRow || player.paused) return;
    paint();
    rafId = requestAnimationFrame(tick);
  };

  player.addEventListener('play', () => {
    if (activeRow) activeRow.classList.add('is-playing');
    cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(tick);
  });

  // Covers our toggle AND external pauses (pauseAllPlayers from script.js)
  player.addEventListener('pause', () => {
    cancelAnimationFrame(rafId);
    if (activeRow) activeRow.classList.remove('is-playing');
  });

  player.addEventListener('ended', () => {
    cancelAnimationFrame(rafId);
    if (activeRow) resetRow(activeRow);
  });

  player.addEventListener('error', () => {
    cancelAnimationFrame(rafId);
    if (activeRow) resetRow(activeRow);
  });
</script>
