---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingSection from '../components/PricingSection.astro';
import { Image } from 'astro:assets';
import newThumbnail from '../assets/images/new-thumbnail.jpg';
import designImg from '../assets/images/design.jpg';
import composeImg from '../assets/images/compose.jpg';
import remixImg from '../assets/images/remix.jpg';
import shareImg from '../assets/images/share.jpg';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Sonura",
    "url": "https://sonurastudio.com/",
    "applicationCategory": "MultimediaApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "category": "Music Production" },
    "description": "The AI studio for music production. Royalty-free beats, loops, vocals, stems, one-shots, and full tracks, all in one place.",
    "image": "https://sonurastudio.com/demo-image.jpeg",
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "ratingCount": "1247" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Sonura",
    "url": "https://sonurastudio.com/",
    "logo": "https://sonurastudio.com/demo-image.jpeg",
    "sameAs": ["https://twitter.com/sonurastudio", "https://discord.gg/Yk8RD3Nmyh"],
    "contactPoint": { "@type": "ContactPoint", "email": "kindred@sonurastudio.com", "contactType": "Customer Support" }
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Sonura",
    "applicationCategory": "MusicApplication",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "operatingSystem": "Web Browser",
    "description": "The AI studio for music production. Royalty-free beats, loops, vocals, stems, and full tracks. Free to start, with full commercial rights."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is Sonura?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sonura is the AI studio for music production. Describe what you want and get professional-quality beats, loops, vocals, and full tracks in seconds. Export stems, iterate endlessly, and use everything commercially."
      }
    },
    {
      "@type": "Question",
      "name": "Is Sonura free to use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You get free credits to start creating immediately. No credit card required. Generate beats, loops, and tracks at full quality before choosing a plan."
      }
    },
    {
      "@type": "Question",
      "name": "Can I monetize the music I create?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Everything you create with Sonura is yours with full commercial rights. Release on Spotify, sell as beats, use in client work. No royalty splits, no attribution required."
      }
    }
  ]
};
---

<BaseLayout
  title="Sonura | The AI Studio for Music Production"
  description="The AI studio for music production. Royalty-free beats, loops, vocals, stems, one-shots, and full tracks, all in one place. Built for producers, artists, and creators."
  keywords="ai music generator, ai music production, ai music studio, ai beat maker, ai loop maker, ai vocals, text to music, ai song generator, beat maker, loop creator, stem export, royalty free music, music production"
  canonical="https://sonurastudio.com/"
  ogTitle="Sonura - The AI Studio for Music Production"
  ogDescription="Royalty-free beats, loops, vocals, stems, one-shots, and full tracks, all in one place."
  jsonLd={[...jsonLd, faqSchema]}
>
  <meta slot="head" property="og:video" content="https://www.youtube.com/watch?v=xUuqIAWetXk" />
  <meta slot="head" property="og:video:type" content="text/html" />
  <meta slot="head" property="og:video:width" content="1920" />
  <meta slot="head" property="og:video:height" content="1080" />
  <section class="hero">
    <div class="hero-background">
      <div class="hero-gradient"></div>
      <div class="hero-noise"></div>
      <svg class="cable-svg" style="z-index: 1;">
        <defs>
          <linearGradient id="cableGradient1" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" style="stop-color:#7c3aed;stop-opacity:0.2" />
            <stop offset="50%" style="stop-color:#a78bfa;stop-opacity:0.6" />
            <stop offset="100%" style="stop-color:#7c3aed;stop-opacity:0.2" />
          </linearGradient>
          <linearGradient id="cableGradient2" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" style="stop-color:#5b21b6;stop-opacity:0.2" />
            <stop offset="50%" style="stop-color:#7c3aed;stop-opacity:0.5" />
            <stop offset="100%" style="stop-color:#5b21b6;stop-opacity:0.2" />
          </linearGradient>
        </defs>
        <path d="M -50 100 C 100 500 400 200 800 50" stroke="url(#cableGradient1)" class="cable-path" fill="none" />
        <path d="M 1400 300 C 1000 700 800 500 400 900" stroke="url(#cableGradient2)" class="cable-path" fill="none" />
      </svg>
    </div>
    <div class="hero-content">
      <h1 class="headline reveal" data-reveal-delay="0.04s">The AI Studio for Music Production</h1>
      <p class="subhead reveal" data-reveal-delay="0.06s">Royalty-free beats, loops, vocals, stems, one-shots, and full tracks, all in one place.</p>

      <div class="cta reveal" data-reveal-delay="0.08s" id="signup">
        <div class="cta-buttons">
          <a id="cta-button" class="button primary" href="https://app.sonurastudio.com/studio">Get Started Free</a>
          <a class="button secondary" href="https://app.sonurastudio.com/samples">Create Samples</a>
        </div>
        <a class="hero-beta-link" href="https://app.sonurastudio.com/sketches">Explore the Community →</a>
      </div>
    </div>
    <div class="hero-video reveal" data-reveal-delay="0.16s" id="hero-video-container">
      <div class="screw tl"></div>
      <div class="screw tr"></div>
      <div class="screw bl"></div>
      <div class="screw br"></div>
      <Image 
        src={newThumbnail}
        alt="Sonura AI Music Generator Demo" 
        class="hero-video-element hero-video-thumbnail"
        id="video-thumbnail"
        style="width: 100%; height: auto; aspect-ratio: 16 / 9; object-fit: cover;"
      />
      <div class="hero-video-overlay" id="video-overlay">
        <div class="video-play-button">
          <i data-lucide="play"></i>
        </div>
      </div>
    </div>
  </section>
  
  <section class="workflow" aria-labelledby="workflow-title">
    <svg class="cable-svg" style="z-index: 0; pointer-events: none; opacity: 0.2;">
       <path d="M 0 100 C 300 100 300 800 600 800 S 900 100 1200 100" stroke="#7c3aed" stroke-width="1" fill="none" />
    </svg>
    <div class="workflow-inner">
      <h2 id="workflow-title" class="workflow-title reveal">
        <span style="display: inline-flex; align-items: center; gap: 16px;">
          <div class="patch-point"></div>
          Everything You Need to Produce
          <div class="patch-point"></div>
        </span>
      </h2>
      <div class="workflow-grid">
        <div class="workflow-item reveal" data-reveal-delay="0.04s">
          <div class="workflow-image synth-panel">
            <div class="screw tl"></div>
            <div class="screw tr"></div>
            <div class="screw bl"></div>
            <div class="screw br"></div>
            <Image src={designImg} alt="Design unique sounds in Sonura" />
          </div>
          <div class="workflow-content">
            <h3 class="workflow-item-title">Create Original Sounds</h3>
            <p class="workflow-item-description">One-shots, vocals, loops, and FX tailored to your exact vision. Every sound is unique, never recycled, and production-ready out of the box.</p>
          </div>
        </div>
        <div class="workflow-item workflow-item-reverse reveal" data-reveal-delay="0.08s">
          <div class="workflow-image synth-panel">
            <div class="screw tl"></div>
            <div class="screw tr"></div>
            <div class="screw bl"></div>
            <div class="screw br"></div>
            <Image src={composeImg} alt="Compose and stack tracks in Sonura" />
          </div>
          <div class="workflow-content">
            <h3 class="workflow-item-title">Compose Full Arrangements</h3>
            <p class="workflow-item-description">Layer drums, bass, melody, and vocals into complex arrangements. Build a full track from a single idea, piece by piece.</p>
          </div>
        </div>
        <div class="workflow-item reveal" data-reveal-delay="0.12s">
          <div class="workflow-image synth-panel">
            <div class="screw tl"></div>
            <div class="screw tr"></div>
            <div class="screw bl"></div>
            <div class="screw br"></div>
            <Image src={remixImg} alt="Remix your music in Sonura" />
          </div>
          <div class="workflow-content">
            <h3 class="workflow-item-title">Export Stems & Remix</h3>
            <p class="workflow-item-description">Export individual stems and bring them into your DAW for full control. Share links so other creators can remix your tracks and stems directly inside Sonura.</p>
          </div>
        </div>
        <div class="workflow-item workflow-item-reverse reveal" data-reveal-delay="0.16s">
          <div class="workflow-image synth-panel">
            <div class="screw tl"></div>
            <div class="screw tr"></div>
            <div class="screw bl"></div>
            <div class="screw br"></div>
            <Image src={shareImg} alt="Share your music with the world" />
          </div>
          <div class="workflow-content">
            <h3 class="workflow-item-title">Publish Anywhere</h3>
            <p class="workflow-item-description">Release to Spotify, YouTube, SoundCloud, or any platform. Full commercial rights. No royalty splits. 100% yours.</p>
          </div>
        </div>
      </div>
      <div class="workflow-cta reveal" data-reveal-delay="0.24s">
        <p class="workflow-cta-text">Built to accelerate your process, not replace your creativity.</p>
        <a class="button primary" href="https://app.sonurastudio.com">Start Creating for Free</a>
      </div>
    </div>
  </section>
  
  <section class="demo" aria-labelledby="demo-title">
    <div class="demo-inner">
      <div class="demo-header">
        <div class="demo-header-content">
          <h2 id="demo-title" class="demo-title">Made with Sonura</h2>
          <p class="demo-subtitle">Tracks from the <a href="https://app.sonurastudio.com/sketches" class="community-link">Sonura community</a></p>
        </div>
      </div>
      <div class="demo-embeds">
        <div class="embed-container reveal">
          <iframe src="https://app.sonurastudio.com/embed/d14d275e-39d4-42bb-8f67-0f4b849a0855" width="100%" height="120" frameborder="0" allow="autoplay; encrypted-media" style="border-radius: 8px;" loading="lazy"></iframe>
        </div>
        <div class="embed-container reveal" data-reveal-delay="0.06s">
          <iframe src="https://app.sonurastudio.com/embed/d4985b2f-0e6d-4792-9cde-da9e8b2dde1b" width="100%" height="120" frameborder="0" allow="autoplay; encrypted-media" style="border-radius: 8px;" loading="lazy"></iframe>
        </div>
        <div class="embed-container reveal" data-reveal-delay="0.12s">
          <iframe src="https://app.sonurastudio.com/embed/c84ad008-2b99-4a02-8321-79e0c8801b84" width="100%" height="120" frameborder="0" allow="autoplay; encrypted-media" style="border-radius: 8px;" loading="lazy"></iframe>
        </div>
      </div>
    </div>
  </section>
  
  <section class="testimonials" aria-labelledby="testimonials-title">
    <div class="testimonials-inner">
      <h2 id="testimonials-title" class="testimonials-title reveal">
        <span class="love-icon-wrapper" aria-hidden="true">
          <i data-lucide="heart" class="love-icon"></i>
        </span>
        Trusted by Creators Worldwide
      </h2>
      <div class="testimonials-grid">
        <div class="testimonial-card reveal" data-reveal-delay="0.04s">
          <div class="testimonial-content">
            <p class="testimonial-text">"Just came across Sonura on Product Hunt and I am completely jazzed by this product! I have numerous projects where I've been dreading doing sound engineering and this has completely flipped the script!"</p>
          </div>
          <div class="testimonial-author">
            <div class="author-info">
              <p class="author-name">Erik Wesslen</p>
              <p class="author-handle">Engineer</p>
            </div>
          </div>
        </div>
        
        <div class="testimonial-card reveal" data-reveal-delay="0.08s">
          <div class="testimonial-content">
            <p class="testimonial-text">"Love the app. Easy to use. I'm using it for video background music and my sets, it makes my videos totally unique."</p>
          </div>
          <div class="testimonial-author">
            <div class="author-info">
              <p class="author-name">Steve B</p>
              <p class="author-handle">DJ</p>
            </div>
          </div>
        </div>
        
        <div class="testimonial-card reveal" data-reveal-delay="0.12s">
          <div class="testimonial-content">
            <p class="testimonial-text">"The perfect balance between complexity and ease of use. I could go from zero to a complete song with almost no learning curve. A real wow moment for me."</p>
          </div>
          <div class="testimonial-author">
            <div class="author-info">
              <p class="author-name">António Ferreira</p>
              <p class="author-handle">Producer</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pricing" id="pricing" aria-labelledby="pricing-title">
    <div class="pricing-inner">
      <PricingSection showHeader={true} showTrust={true} />
    </div>
  </section>
  
  <section class="faq" id="faq" aria-labelledby="faq-title">
    <div class="faq-inner">
      <h2 id="faq-title" class="faq-title">Frequently asked questions</h2>
      <div class="faq-list">
        <details class="reveal">
          <summary>What is Sonura?</summary>
          <p>Sonura is the AI studio for music production. Describe what you want and get professional-quality beats, loops, vocals, and full tracks in seconds. Export stems, iterate endlessly, and use everything commercially.</p>
        </details>
        <details class="reveal" data-reveal-delay="0.03s">
          <summary>Is Sonura free to use?</summary>
          <p>Yes. You get free credits to start creating immediately. No credit card required. Generate beats, loops, and tracks at full quality before choosing a plan.</p>
        </details>
        <details class="reveal" data-reveal-delay="0.06s">
          <summary>Can I monetize the music I create?</summary>
          <p>Everything you create with Sonura is yours with full commercial rights. Release on Spotify, sell as beats, use in client work, score a film. No royalty splits, no attribution required.</p>
        </details>
        <details class="reveal" data-reveal-delay="0.12s">
          <summary>What genres does Sonura support?</summary>
          <p>Virtually every genre: trap, house, techno, pop, rock, jazz, lo-fi, drill, R&B, country, ambient, cinematic, and more. Sonura understands sub-genres and specific style descriptors so you get exactly the sound you're after.</p>
        </details>
        <details class="reveal" data-reveal-delay="0.18s">
          <summary>Do I need production experience?</summary>
          <p>No. Sonura works for complete beginners and professional producers alike. If you can describe what you want, you can create it. No DAW knowledge or music theory required, though it integrates seamlessly if you have them.</p>
        </details>
        <details class="reveal" data-reveal-delay="0.24s">
          <summary>How fast is generation?</summary>
          <p>Under 10 seconds on average. Loops in 5–8 seconds, full tracks in 8–12 seconds. No queues, no rendering delays.</p>
        </details>
        <details class="reveal" data-reveal-delay="0.3s">
          <summary>Can I export stems for my DAW?</summary>
          <p>Yes. Export individual stems (drums, bass, melody, FX, vocals) or the full mix. Compatible with Ableton, FL Studio, Logic, Pro Tools, and any DAW.</p>
        </details>
        <details class="reveal" data-reveal-delay="0.36s">
          <summary>How is Sonura different from sample packs?</summary>
          <p>Sample packs are pre-made and shared across thousands of producers. Sonura generates completely original audio tailored to your exact specifications. Every creation is unique and matched to your vision.</p>
        </details>
        <details class="reveal" data-reveal-delay="0.42s">
          <summary>What makes Sonura different from other AI music tools?</summary>
          <p>Sonura is built for producers, not just listeners. You get stem exports, multi-track layering, real-time iteration, full commercial rights, and studio-grade output, all in one platform. Most AI music tools generate a finished song you can't edit. Sonura gives you the building blocks.</p>
        </details>
      </div>
    </div>
  </section>

  <section class="final-cta" aria-labelledby="final-cta-title">
    <div class="final-cta-inner">
      <h2 id="final-cta-title" class="final-cta-title reveal">Start producing. Right now.</h2>
      <p class="final-cta-subtitle reveal" data-reveal-delay="0.06s">Free to start. No credit card. No setup.</p>
      <div class="final-cta-form reveal" data-reveal-delay="0.12s">
        <a class="button primary large" href="https://app.sonurastudio.com">Get Started Free</a>
      </div>
      <div class="final-cta-trust reveal" data-reveal-delay="0.18s">
        <div class="trust-item"><i data-lucide="check"></i> <span>No credit card required</span></div>
        <div class="trust-item"><i data-lucide="check"></i> <span>Cancel anytime</span></div>
        <div class="trust-item"><i data-lucide="check"></i> <span>Full commercial rights</span></div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Video play functionality
  document.getElementById('video-overlay')?.addEventListener('click', () => {
    const container = document.getElementById('hero-video-container');
    const thumbnail = document.getElementById('video-thumbnail');
    const overlay = document.getElementById('video-overlay');
    
    if (container && thumbnail && overlay) {
      const iframe = document.createElement('iframe');
      iframe.src = 'https://www.youtube.com/embed/xUuqIAWetXk?autoplay=1';
      iframe.className = 'hero-video-element';
      iframe.style.cssText = 'width: 100%; height: auto; aspect-ratio: 16 / 9; border-radius: 12px;';
      iframe.frameBorder = '0';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      
      thumbnail.replaceWith(iframe);
      overlay.style.display = 'none';
    }
  });
</script>

<style>
  .hero-content {
    padding-top: 120px !important;
  }
</style>
