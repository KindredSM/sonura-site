const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is Sonura?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sonura is the AI studio for music production. Describe what you want and get professional-quality beats, loops, vocals, and full tracks in seconds. Export stems, iterate endlessly, and use everything commercially."
      }
    },
    {
      "@type": "Question",
      "name": "Is Sonura free to use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You get free credits to start creating immediately. No credit card required. Create beats, loops, and tracks at full quality before choosing a plan."
      }
    },
    {
      "@type": "Question",
      "name": "Can I monetize the music I create?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Everything you create with Sonura is yours with full commercial rights. Release on Spotify, sell as beats, use in client work. No royalty splits, no attribution required."
      }
    },
    {
      "@type": "Question",
      "name": "Will platforms de-rank my music if I use AI tools?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sonura is for those crafting original arrangements and sound, not replacing the human decisions that make a track yours."
      }
    }
  ]
};

