---
import BaseLayout from '../../layouts/BaseLayout.astro';

const sampleTypes = [
  { name: 'Beat Producers', slug: 'beat-producers', audience: 'Producers', description: 'Unique loops and one-shots you can flip into beats and sell. No shared packs.' },
  { name: 'Hip-Hop Producers', slug: 'hip-hop-producers', audience: 'Hip-Hop', description: 'Trap, drill, and boom bap samples made to order for your next beat.' },
  { name: 'Electronic Producers', slug: 'electronic-producers', audience: 'Electronic', description: 'House, techno, and EDM sounds: basslines, stabs, and FX on demand.' },
  { name: 'Vocal Samples', slug: 'ai-vocals-producers', audience: 'Vocals', description: 'Vocal chops, hooks, and ad-libs to layer into your productions.' },
  { name: 'For Vocalists', slug: 'vocalists', audience: 'Vocalists', description: 'Custom backing tracks and samples for practice, demos, and performances.' },
  { name: 'For Songwriters', slug: 'songwriters', audience: 'Songwriters', description: 'Instrumentals and samples to spark new songs and beat writer\'s block.' },
  { name: 'For Content Creators', slug: 'content-creators', audience: 'Creators', description: 'Royalty-free music and FX for videos, streams, and social content.' },
  { name: 'For Video Editors', slug: 'video-editors', audience: 'Video', description: 'Copyright-free music, transitions, and SFX that clear on every platform.' },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Sonura AI Sample Generator",
    "description": "Create unique, royalty-free samples on demand for producers, vocalists, songwriters, and creators.",
    "url": "https://sonurastudio.com/samples/"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sonurastudio.com/" },
      { "@type": "ListItem", "position": 2, "name": "Samples", "item": "https://sonurastudio.com/samples/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": sampleTypes.map((type, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": type.name,
      "url": `https://sonurastudio.com/samples/${type.slug}/`
    }))
  }
];
---

<BaseLayout
  title="AI Sample Generator | Unique Royalty-Free Samples on Demand - Sonura"
  description="Create unique loops, one-shots, vocals, and FX on demand: original samples you own, not shared packs. For producers, vocalists, songwriters, and creators. Free to start."
  keywords="ai sample generator, sample packs, unique samples, royalty-free samples, one-shots, vocal chops, loops for producers"
  canonical="https://sonurastudio.com/samples/"
  ogTitle="Sonura AI Sample Generator"
  ogDescription="Create unique, royalty-free samples on demand for producers, vocalists, songwriters, and creators."
  jsonLd={jsonLd}
>
  <style>
    .sample-hub {
      padding: clamp(56px, 9vh, 110px) var(--page-pad) clamp(96px, 12vw, 140px);
    }

    .sample-hub-header {
      text-align: left;
      margin-bottom: clamp(56px, 8vw, 88px);
    }

    .sample-hub-header h1 {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(48px, 7vw, 104px);
      line-height: 0.98;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      margin: 0 0 28px;
      color: var(--fg);
    }

    .sample-hub-header p {
      font-size: 17px;
      color: var(--muted);
      max-width: 560px;
      margin: 0;
      text-transform: lowercase;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      line-height: 1.8;
    }

    .sample-hub-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: var(--radius-panel);
    }

    @media (min-width: 640px) {
      .sample-hub-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (min-width: 1024px) {
      .sample-hub-grid { grid-template-columns: repeat(4, 1fr); }
    }

    .sample-card {
      padding: 28px;
      background: var(--bg);
      border-radius: var(--radius-panel);
      transition: background 0.2s;
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .sample-card:hover {
      background: var(--panel-bg);
    }

    .sample-card-audience {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--primary);
      margin-bottom: 14px;
      font-weight: 600;
    }

    .sample-card-name {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 12px;
      color: var(--fg);
    }

    .sample-card-desc {
      color: var(--muted);
      text-transform: lowercase;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      line-height: 1.8;
      font-size: 14px;
      margin: 0;
    }

    .sample-card-arrow {
      margin-top: 18px;
      color: var(--fg);
      font-weight: 500;
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .sample-hub-cta {
      text-align: left;
      margin-top: clamp(72px, 9vw, 110px);
      padding: clamp(48px, 7vw, 96px) clamp(28px, 5vw, 80px);
      border: 1px solid var(--hairline);
      border-radius: var(--radius-panel);
      background: var(--bg);
    }

    .sample-hub-cta h2 {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(38px, 4.8vw, 68px);
      letter-spacing: 0.01em;
      line-height: 1;
      text-transform: uppercase;
      margin: 0 0 24px;
      color: var(--fg);
    }

    .sample-hub-cta p:not(.section-kicker) {
      color: var(--muted);
      margin: 0 0 36px;
      max-width: 560px;
      text-transform: lowercase;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      line-height: 1.8;
      font-size: 15px;
    }
  </style>

  <div class="sample-hub">
    <header class="sample-hub-header">
      <h1>Create Samples No One Else Has</h1>
      <p>Stop digging through the same packs everyone else uses. Create unique loops, one-shots, vocals, and FX on demand. Original sounds you own outright, ready for any release.</p>
    </header>

    <p class="section-kicker">01 / Samples</p>
    <div class="sample-hub-grid">
      {sampleTypes.map((type) => (
        <a href={`/samples/${type.slug}/`} class="sample-card">
          <div class="sample-card-audience">{type.audience}</div>
          <div class="sample-card-name">{type.name}</div>
          <p class="sample-card-desc">{type.description}</p>
          <div class="sample-card-arrow">Learn more →</div>
        </a>
      ))}
    </div>

    <div class="sample-hub-cta">
      <p class="section-kicker">02 / Get started</p>
      <h2>Original Sounds, Full Rights</h2>
      <p>Every sample is created for you and yours to release commercially. Free to start, no credit card required.</p>
      <a href="https://app.sonurastudio.com/studio" class="button primary large"><span class="btn-label-full">Start Creating Free</span><span class="btn-label-short">Start free</span></a>
    </div>
  </div>
</BaseLayout>
