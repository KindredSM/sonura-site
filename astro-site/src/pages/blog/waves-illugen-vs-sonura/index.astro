    padding: 16px 20px 16px 0;
    text-align: left;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--hairline);
  }
  .alt-table th.col-sonura {
    color: var(--fg);
  }
  .alt-table td {
    padding: 18px 20px 18px 0;
    text-align: left;
    vertical-align: top;
    font-size: 15px;
    line-height: 1.6;
  }
  .alt-table tbody tr {
    border-top: 1px solid var(--hairline);
  }
  .alt-table tbody tr:first-child {
    border-top: 0;
  }
  .alt-table .cell-feature {
    font-weight: 600;
    color: var(--fg);
  }
  .alt-table .cell-strong {
    color: var(--fg);
  }
  .alt-table .cell-weak {
    color: var(--muted);
  }
</style>
