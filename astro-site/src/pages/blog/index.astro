---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Define all blog posts here - single source of truth
const blogPosts = [
  {
    slug: 'is-ai-music-ethical',
    title: 'Is AI Music Ethical? Licensed vs Scraped Models, Explained',
    description: 'Whether AI music is "ethical" comes down to two things: was the model trained with consent, and is there real human authorship in the track. Here is how licensed AI music actually works.',
    date: '2026-07-02',
    readTime: '7 min read',
    tag: 'Industry',
  },
  {
    slug: 'is-ai-music-allowed-on-spotify',
    title: 'Is AI Music Allowed on Spotify? What the 2026 Rules Actually Say',
    description: 'Yes, AI-assisted music is allowed on Spotify. What gets removed is spam, impersonation, and artificial streaming. Here is the real line between AI-assisted production and content-farm uploads.',
    date: '2026-07-02',
    readTime: '6 min read',
    tag: 'Industry',
  },
  {
    slug: 'ai-music-consent-vs-fraud-2026',
    title: 'AI Music in 2026: The Industry Split Between Consent and Fraud',
    description: 'The music industry is living in two realities. One side runs on licensed AI and label deals. The other runs on 60,000 fake tracks a day. Both are accelerating.',
    date: '2026-04-15',
    readTime: '9 min read',
    tag: 'Industry',
  },
  {
    slug: 'ai-sample-generator-unique-samples',
    title: 'Why AI-Generated Samples Beat Generic Sample Libraries',
    description: 'Sample libraries are overused and generic. Discover how AI-generated samples create unique sounds on-demand, giving your music the originality it needs to stand out.',
    date: '2025-01-15',
    readTime: '5 min read',
    tag: 'Guide',
  },
  {
    slug: 'ai-music-genjam-sonura-studio',
    title: 'AI Music GenJam - Sonura Studio',
    description: 'Join the first-ever AI Music GenJam by Sonura Studio in San Francisco. Collaborate, create, and compete for prizes in this hands-on AI music event.',
    date: '2025-12-10', // Assuming date from content
    readTime: '3 min read',
    tag: 'Event',
  },
  {
    slug: 'how-to-make-trap-beats',
    title: 'How to Make Trap Beats: Complete Guide for Beginners',
    description: 'Learn how to make professional trap beats from scratch. Complete guide covering 808s, hi-hats, melodies, mixing, and modern production techniques.',
    date: '2025-10-15',
    readTime: '5 min read',
    tag: 'Tutorial',
  },
  {
    slug: 'ai-music-generator-guide',
    title: 'AI Music Generators: Complete Guide 2026',
    description: 'Comprehensive guide to AI music generators. Compare features, pricing, quality, and commercial use rights to choose the best tool for your needs.',
    date: '2025-10-20',
    readTime: '4 min read',
    tag: 'Guide',
  },
  {
    slug: 'royalty-free-music-explained',
    title: 'Royalty-Free Music Explained: Complete Guide',
    description: 'Learn what royalty-free means, licensing types, YouTube copyright rules, and how to use music commercially without legal issues.',
    date: '2025-10-10',
    readTime: '3 min read',
    tag: 'Education',
  },
  {
    slug: 'how-to-release-music-on-spotify',
    title: 'How to Release Music on Spotify: Complete Guide',
    description: 'Step-by-step guide to releasing music on Spotify as an independent artist. Distribution, playlisting, and maximizing streams.',
    date: '2025-09-20',
    readTime: '6 min read',
    tag: 'Release Strategy',
  },
  {
    slug: 'music-production-for-beginners',
    title: 'Music Production for Beginners: Complete Guide',
    description: 'Start making music from scratch. Equipment, DAWs, music theory basics, and modern production techniques to launch your journey.',
    date: '2025-10-05',
    readTime: '6 min read',
    tag: 'Beginner Guide',
  },
  {
    slug: 'best-free-vst-plugins',
    title: 'Best Free VST Plugins for Music Production 2026',
    description: '30+ professional free VST plugins including synths, effects, drums, and mixing tools. Save thousands on your production setup.',
    date: '2025-09-28',
    readTime: '6 min read',
    tag: 'Resource Guide',
  }
];

// Slash metadata: "02 JUL 2026 / 7 MIN"
const fmtMeta = (date: string, readTime: string) => {
  const d = new Date(date);
  const day = String(d.getUTCDate()).padStart(2, '0');
  const month = d.toLocaleDateString('en-US', { month: 'short', timeZone: 'UTC' }).toUpperCase();
  const mins = parseInt(readTime, 10);
  return `${day} ${month} ${d.getUTCFullYear()} / ${mins} MIN`;
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "Sonura Blog",
    "description": "Music production tips, AI music tutorials, and guides from Sonura.",
    "url": "https://sonurastudio.com/blog/"
  }
];
---

<BaseLayout
  title="Sonura Blog | Music Production Tips, Guides & AI Music Tutorials"
  description="Learn music production, AI music generation, beat making, and release strategies. Expert guides, tutorials, and tips from Sonura."
  keywords="music production blog, ai music tutorials, beat making guide, music production tips, how to make beats"
  canonical="https://sonurastudio.com/blog/"
  ogTitle="Sonura Blog | Music Production Tips & Guides"
  jsonLd={jsonLd}
>
  <style>
    .blog-index {
      padding: clamp(56px, 8vh, 90px) var(--page-pad) clamp(72px, 9vw, 110px);
    }
    .blog-index-header {
      text-align: left;
      margin-bottom: 56px;
    }
    .blog-index-title {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(48px, 6.5vw, 92px);
      line-height: 1;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--fg);
      margin: 0 0 20px;
    }
    .blog-index-sub {
      font-size: 17px;
      color: var(--muted);
      text-transform: lowercase;
      letter-spacing: 0.022em;
      line-height: 1.8;
      word-spacing: 0.04em;
      max-width: 560px;
      margin: 0;
    }
    .blog-card {
      background: transparent;
      border: 1px solid var(--border-light);
      border-radius: var(--radius-panel);
      padding: 32px;
      transition: border-color 0.2s ease;
      display: flex;
      flex-direction: column;
      cursor: pointer;
      height: 100%;
    }
    .blog-card:hover {
      border-color: var(--fg);
    }
    .blog-card-tag {
      display: inline-block;
      padding: 5px 10px;
      border: 1px solid var(--border-light);
      border-radius: var(--radius-ui);
      color: var(--muted);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .blog-card-title {
      font-size: 22px;
      font-weight: 700;
      line-height: 1.3;
      margin: 0 0 12px;
      color: var(--fg);
    }
    .blog-card-blurb {
      color: var(--muted);
      margin: 0 0 20px;
      font-size: 15px;
      line-height: 1.8;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      text-transform: lowercase;
      flex-grow: 1;
    }
    .blog-card-meta {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .blog-card-more {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--fg);
    }
    /* Grid layout */
    .blog-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 32px;
    }
    .blog-cta {
      border-top: 1px solid var(--hairline);
      padding: clamp(72px, 9vw, 110px) var(--page-pad);
    }
    .blog-cta-title {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(38px, 4.8vw, 68px);
      line-height: 1;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--fg);
      margin: 0 0 24px;
    }
    .blog-cta-sub {
      font-size: 17px;
      color: var(--muted);
      text-transform: lowercase;
      letter-spacing: 0.022em;
      line-height: 1.8;
      word-spacing: 0.04em;
      max-width: 560px;
      margin: 0 0 32px;
    }
  </style>

  <section class="blog-index">
    <header class="blog-index-header">
      <p class="section-kicker">01 / Journal</p>
      <h1 class="blog-index-title">Sonura Blog</h1>
      <p class="blog-index-sub">Guides, tutorials, and tips for music production, AI music creation, and releasing your tracks.</p>
    </header>

    <div class="blog-grid">
      {blogPosts.map((post) => (
        <a href={`/blog/${post.slug}/`} style="text-decoration: none; color: inherit; display: block;">
          <article class="blog-card">
            <div style="margin-bottom: 16px;">
              <span class="blog-card-tag">{post.tag}</span>
            </div>
            <h2 class="blog-card-title">{post.title}</h2>
            <p class="blog-card-blurb">{post.description}</p>
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 16px;">
              <span class="blog-card-meta">{fmtMeta(post.date, post.readTime)}</span>
              <span class="blog-card-more">Read more →</span>
            </div>
          </article>
        </a>
      ))}
    </div>
  </section>

  <section class="blog-cta">
    <div style="max-width: 800px;">
      <p class="section-kicker">02 / Start</p>
      <h2 class="blog-cta-title">Ready to Start Creating?</h2>
      <p class="blog-cta-sub">Create professional music in seconds with Sonura's AI music generator.</p>
      <a href="https://app.sonurastudio.com/studio" class="button primary large" style="display: inline-block; background: var(--fg); color: var(--bg); text-decoration: none; border-radius: var(--radius-ui);">Try Sonura Free</a>
    </div>
  </section>
</BaseLayout>
