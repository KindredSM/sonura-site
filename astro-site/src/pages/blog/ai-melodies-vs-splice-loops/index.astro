import BlogLayout from '../../../layouts/BlogLayout.astro';

const toc = [
  { id: 'splice-loops', label: 'What Splice loops are' },
  { id: 'ai-melodies', label: 'What AI melodies do differently' },
  { id: 'shared-vs-original', label: 'Shared vs original' },
  { id: 'use-both', label: 'Use both' },
  { id: 'faq', label: 'FAQ' },
