<script>
  // @ts-nocheck
  const PLUGIN_VERSION = '1.1.3';
  const MAC_URL = `https://audio.sonurastudio.com/sonura-plugin/SonuraFlow-v${PLUGIN_VERSION}-macOS.pkg`;
  const WIN_URL = `https://audio.sonurastudio.com/sonura-plugin/SonuraFlow-v${PLUGIN_VERSION}-Windows-Setup.exe`;

  const isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform) || /Macintosh/.test(navigator.userAgent);

  const trackDownload = (platform, location) => {
    const url = platform === 'mac' ? MAC_URL : WIN_URL;
    const fileName = url.split('/').pop();
    const fileExtension = platform === 'mac' ? 'pkg' : 'exe';

    if (typeof window.gtag === 'function') {
      window.gtag('event', 'plugin_download', {
        plugin_platform: platform,
        plugin_version: PLUGIN_VERSION,
        plugin_location: location,
        file_name: fileName,
        file_extension: fileExtension,
        link_url: url,
        transport_type: 'beacon',
      });
      window.gtag('event', 'file_download', {
        file_name: fileName,
        file_extension: fileExtension,
        link_url: url,
        transport_type: 'beacon',
      });
    }

    if (typeof window.fbq === 'function') {
      window.fbq('trackCustom', 'PluginDownload', {
        platform,
        version: PLUGIN_VERSION,
        location,
      });
      window.fbq('track', 'Lead', {
        content_name: 'Sonura Flow Plugin',
        content_category: platform,
      });
    }

    if (typeof window.dataLayer !== 'undefined') {
      window.dataLayer.push({
        event: 'plugin_download',
        plugin_platform: platform,
        plugin_version: PLUGIN_VERSION,
        plugin_location: location,
      });
    }
  };

  const setupDownload = (primaryId, primaryLabelId, altId, altLabelId, location) => {
    const primaryBtn = document.getElementById(primaryId);
    const primaryLabel = document.getElementById(primaryLabelId);
    const altBtn = document.getElementById(altId);
    const altLabel = document.getElementById(altLabelId);
    if (!primaryBtn || !altBtn) return;

    const primaryPlatform = isMac ? 'mac' : 'windows';
    const altPlatform = isMac ? 'windows' : 'mac';

    if (isMac) {
      primaryBtn.href = MAC_URL;
      primaryLabel.textContent = 'Download for Mac';
      altBtn.href = WIN_URL;
      altLabel.textContent = 'Download for Windows';
    } else {
      primaryBtn.href = WIN_URL;
      primaryLabel.textContent = 'Download for Windows';
      altBtn.href = MAC_URL;
      altLabel.textContent = 'Download for Mac';
    }

    primaryBtn.addEventListener('click', () => trackDownload(primaryPlatform, location));
    altBtn.addEventListener('click', () => trackDownload(altPlatform, location));
  };

  setupDownload('dl-primary', 'dl-primary-label', 'dl-alt', 'dl-alt-label', 'hero');
  setupDownload('dl-primary-b', 'dl-primary-label-b', 'dl-alt-b', 'dl-alt-label-b', 'cta');

  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap === 'undefined') return;

    const items = document.querySelectorAll('.anim');
    gsap.set(items, { opacity: 0, y: 30 });
    gsap.to(items, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power3.out',
      stagger: 0.1,
      delay: 0.15,
    });

    const device = document.querySelector('.pg-device');
    if (device) {
      gsap.set(device, { rotateY: 10, rotateX: -4, scale: 0.94 });
      gsap.to(device, {
        rotateY: 0,
        rotateX: 0,
        scale: 1,
        duration: 1.3,
        ease: 'power3.out',
        delay: 0.3,
      });

      gsap.to(device, {
        y: -12,
        duration: 3.5,
        ease: 'sine.inOut',
        yoyo: true,
        repeat: -1,
        delay: 1.6,
      });
    }

    const chip1 = document.querySelector('.pg-chip-1');
    const chip2 = document.querySelector('.pg-chip-2');
    if (chip1) {
      gsap.set(chip1, { opacity: 0, x: -20 });
      gsap.to(chip1, {
        opacity: 1,
        x: 0,
        duration: 0.6,
        ease: 'power2.out',
        delay: 0.9,
        onComplete: () => {
          gsap.to(chip1, {
            y: -14,
            x: 6,
            rotate: -1.5,
            duration: 4.2,
            ease: 'sine.inOut',
            yoyo: true,
            repeat: -1,
          });
        },
      });
    }
    if (chip2) {
      gsap.set(chip2, { opacity: 0, x: 20 });
      gsap.to(chip2, {
        opacity: 1,
        x: 0,
        duration: 0.6,
        ease: 'power2.out',
        delay: 1.1,
        onComplete: () => {
          gsap.to(chip2, {
            y: 12,
            x: -6,
            rotate: 1.5,
            duration: 5,
            ease: 'sine.inOut',
            yoyo: true,
            repeat: -1,
            delay: 0.4,
          });
        },
      });
    }

    const features = document.querySelectorAll('.pg-features li');
    if (features.length) {
      gsap.set(features, { opacity: 0, y: 16 });
      gsap.to(features, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: 'power2.out',
        stagger: 0.08,
        delay: 0.6,
      });
    }

    const faqItems = document.querySelectorAll('.pg-faq details');
    if (faqItems.length && typeof ScrollTrigger !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);
      gsap.set(faqItems, { opacity: 0, y: 20 });
      gsap.to(faqItems, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: 'power2.out',
        stagger: 0.05,
        scrollTrigger: {
          trigger: '.pg-faq',
          start: 'top 80%',
          once: true,
        },
      });
    }

    const bentoCards = document.querySelectorAll('.bento-card');
    if (bentoCards.length && typeof ScrollTrigger !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);
      gsap.set(bentoCards, { opacity: 0, y: 40 });
      gsap.to(bentoCards, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: 'power3.out',
        stagger: 0.09,
        scrollTrigger: {
          trigger: '.pg-showcase',
          start: 'top 75%',
          once: true,
        },
      });
    } else if (bentoCards.length) {
      gsap.set(bentoCards, { opacity: 0, y: 40 });
      gsap.to(bentoCards, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: 'power3.out',
        stagger: 0.09,
        delay: 0.5,
      });
    }
  });
</script>

<style>
  .pg {
    position: relative;
    max-width: 1240px;
    margin: 0 auto;
    width: 100%;
    padding: 80px 32px 180px;
    display: flex;
    flex-direction: column;
    gap: 180px;
    min-height: 100vh;
    overflow-x: clip;
  }

  .pg-glow {
    position: absolute;
    top: 0%;
    left: 15%;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.04) 0%, transparent 70%);
    opacity: 1;
    pointer-events: none;
    filter: blur(120px);
  }

  .pg-glow-b {
    position: absolute;
    top: 30%;
    right: -10%;
    width: 550px;
    height: 550px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.03) 0%, transparent 70%);
    opacity: 1;
    pointer-events: none;
    filter: blur(100px);
  }

  .pg-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.35;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
  }

  .pg-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: 80px;
    align-items: center;
    width: 100%;
    position: relative;
  }

  .pg-left {
    display: flex;
    flex-direction: column;
    gap: 28px;
    min-width: 0;
  }

  .pg-left h1 {
    margin: 0;
    font-size: clamp(56px, 9vw, 112px);
    line-height: 0.92;
    letter-spacing: -0.045em;
    font-weight: 700;
    display: flex;
    flex-direction: column;
  }

  .h1-row {
    background: linear-gradient(to bottom, #fff 20%, #a1a1aa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
