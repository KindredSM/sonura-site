      <p class="pg-cta-sub">Download Sonura Flow and load it up. Free with your Sonura account.</p>
      <div class="pg-download pg-cta-download">
        <a class="dl-btn primary-dl" id="dl-primary-b" href={MAC_URL} download>
          <svg class="dl-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <span id="dl-primary-label-b">Download for Mac</span>
        </a>
        <a class="dl-btn alt-dl" id="dl-alt-b" href={WIN_URL} download>
          <span id="dl-alt-label-b">Download for Windows</span>
        </a>
      </div>
      <div class="pg-os pg-cta-os">
        <div class="os-badge">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <span>macOS 12+</span>
        </div>
        <div class="os-badge">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 5.548l7.065-0.964v6.817H3V5.548zm0 12.904l7.065 0.964V12.6H3v5.852zm7.937 1.048L21 20.936V12.6H10.937v6.9zM10.937 4.5L21 3.064V11.4H10.937V4.5z"/></svg>
          <span>Windows 10+</span>
        </div>
      </div>
    </section>
  </div>

</BaseLayout>

<script define:vars={{ PLUGIN_VERSION, MAC_URL, WIN_URL }}>
  // @ts-nocheck
  const isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform) || /Macintosh/.test(navigator.userAgent);

  const trackDownload = (platform, location, button) => {
    const url = platform === 'mac' ? MAC_URL : WIN_URL;
    const fileName = url.split('/').pop();
    const fileExtension = platform === 'mac' ? 'pkg' : 'exe';

    if (typeof window.gtag === 'function') {
      window.gtag('event', 'plugin_download', {
        plugin_platform: platform,
        plugin_version: PLUGIN_VERSION,
        plugin_location: location,
        plugin_button: button,
        file_name: fileName,
        file_extension: fileExtension,
        link_url: url,
        transport_type: 'beacon',
      });
      window.gtag('event', 'file_download', {
        file_name: fileName,
        file_extension: fileExtension,
        link_url: url,
        transport_type: 'beacon',
      });
    }

    if (typeof window.fbq === 'function') {
      window.fbq('trackCustom', 'PluginDownload', {
        platform,
        version: PLUGIN_VERSION,
        location,
        button,
      });
      window.fbq('track', 'Lead', {
        content_name: 'Sonura Flow Plugin',
        content_category: platform,
      });
    }

    if (typeof window.dataLayer !== 'undefined') {
      window.dataLayer.push({
        event: 'plugin_download',
        plugin_platform: platform,
        plugin_version: PLUGIN_VERSION,
        plugin_location: location,
        plugin_button: button,
      });
    }
  };

  const setupDownload = (primaryId, primaryLabelId, altId, altLabelId, location) => {
    const primaryBtn = document.getElementById(primaryId);
    const primaryLabel = document.getElementById(primaryLabelId);
    const altBtn = document.getElementById(altId);
    const altLabel = document.getElementById(altLabelId);
    if (!primaryBtn || !altBtn) return;

    const primaryPlatform = isMac ? 'mac' : 'windows';
    const altPlatform = isMac ? 'windows' : 'mac';

    if (isMac) {
      primaryBtn.href = MAC_URL;
      primaryLabel.textContent = 'Download for Mac';
      altBtn.href = WIN_URL;
      altLabel.textContent = 'Download for Windows';
    } else {
      primaryBtn.href = WIN_URL;
      primaryLabel.textContent = 'Download for Windows';
      altBtn.href = MAC_URL;
      altLabel.textContent = 'Download for Mac';
    }

    primaryBtn.addEventListener('click', () => trackDownload(primaryPlatform, location, 'primary'));
    altBtn.addEventListener('click', () => trackDownload(altPlatform, location, 'alt'));
  };

  setupDownload('dl-primary', 'dl-primary-label', 'dl-alt', 'dl-alt-label', 'hero');
  setupDownload('dl-primary-b', 'dl-primary-label-b', 'dl-alt-b', 'dl-alt-label-b', 'cta');

  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap === 'undefined') return;

    const items = document.querySelectorAll('.anim');
    gsap.set(items, { opacity: 0, y: 30 });
    gsap.to(items, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power3.out',
      stagger: 0.1,
      delay: 0.15,
    });

    const device = document.querySelector('.pg-device');
    if (device) {
      gsap.set(device, { rotateY: 10, rotateX: -4, scale: 0.94 });
      gsap.to(device, {
        rotateY: 0,
        rotateX: 0,
        scale: 1,
        duration: 1.3,
        ease: 'power3.out',
        delay: 0.3,
      });

      gsap.to(device, {
        y: -12,
        duration: 3.5,
        ease: 'sine.inOut',
        yoyo: true,
        repeat: -1,
        delay: 1.6,
      });
    }

    const chip1 = document.querySelector('.pg-chip-1');
    const chip2 = document.querySelector('.pg-chip-2');
    if (chip1) {
      gsap.set(chip1, { opacity: 0, x: -20 });
      gsap.to(chip1, {
        opacity: 1,
        x: 0,
        duration: 0.6,
        ease: 'power2.out',
        delay: 0.9,
        onComplete: () => {
          gsap.to(chip1, {
            y: -14,
            x: 6,
            rotate: -1.5,
            duration: 4.2,
            ease: 'sine.inOut',
            yoyo: true,
            repeat: -1,
          });
        },
      });
    }
    if (chip2) {
      gsap.set(chip2, { opacity: 0, x: 20 });
      gsap.to(chip2, {
        opacity: 1,
        x: 0,
        duration: 0.6,
        ease: 'power2.out',
        delay: 1.1,
        onComplete: () => {
          gsap.to(chip2, {
            y: 12,
            x: -6,
            rotate: 1.5,
            duration: 5,
            ease: 'sine.inOut',
            yoyo: true,
            repeat: -1,
            delay: 0.4,
          });
        },
      });
    }

    const features = document.querySelectorAll('.pg-features li');
    if (features.length) {
      gsap.set(features, { opacity: 0, y: 16 });
      gsap.to(features, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: 'power2.out',
        stagger: 0.08,
        delay: 0.6,
      });
    }

    const faqItems = document.querySelectorAll('.pg-faq details');
    if (faqItems.length && typeof ScrollTrigger !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);
      gsap.set(faqItems, { opacity: 0, y: 20 });
      gsap.to(faqItems, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: 'power2.out',
        stagger: 0.05,
        scrollTrigger: {
          trigger: '.pg-faq',
          start: 'top 80%',
          once: true,
        },
      });
    }

    const bentoCards = document.querySelectorAll('.bento-card');
    if (bentoCards.length && typeof ScrollTrigger !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);
      gsap.set(bentoCards, { opacity: 0, y: 40 });
      gsap.to(bentoCards, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: 'power3.out',
        stagger: 0.09,
        scrollTrigger: {
          trigger: '.pg-showcase',
          start: 'top 75%',
          once: true,
        },
      });
    } else if (bentoCards.length) {
      gsap.set(bentoCards, { opacity: 0, y: 40 });
      gsap.to(bentoCards, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: 'power3.out',
        stagger: 0.09,
        delay: 0.5,
      });
    }
  });
</script>

