---
import BaseLayout from '../../layouts/BaseLayout.astro';

const PLUGIN_VERSION = '1.2.3';
const MAC_URL = `https://audio.sonurastudio.com/sonura-plugin/SonuraFlow-v${PLUGIN_VERSION}-macOS.pkg`;
const WIN_URL = `https://audio.sonurastudio.com/sonura-plugin/SonuraFlow-v${PLUGIN_VERSION}-Windows-Setup.exe`;

const faqs = [
  {
    question: 'What DAWs does Sonura Flow work with?',
    answer: 'Sonura Flow is a VST3 and AU plugin, so it works with any major DAW: Ableton Live, Logic Pro, FL Studio, Studio One, Bitwig, Cubase, Reaper, GarageBand, and more. If your DAW loads VST3 or AU plugins, you can use it.'
  },
  {
    question: 'Is Sonura Flow free?',
    answer: 'Yes. The plugin is included with any Sonura account, including the free tier. Download it, sign in, and start generating sounds inside your DAW.'
  },
  {
    question: 'What operating systems are supported?',
    answer: 'Sonura Flow runs on macOS 12 Monterey or later (Apple Silicon and Intel) and Windows 10 or later (64-bit). Installers are available for both platforms on this page.'
  },
  {
    question: 'Do I own the sounds I generate?',
    answer: 'Yes. Every sound you create with Sonura Flow is fully royalty-free and yours to use forever, including in commercial releases, sync placements, streaming, and client work. No attribution required.'
  },
  {
    question: 'How do I get the sounds into my project?',
    answer: 'Sounds generated in the plugin drop straight into your DAW timeline as audio. Drag them onto a track or use the plugin\'s built-in export. No bouncing, no re-importing, no switching apps.'
  },
  {
    question: 'What if the plugin does not show up in my DAW?',
    answer: 'Restart your DAW, rescan plugins, and check the right plugin format for your setup. Logic Pro and GarageBand use AU on Mac, while Ableton Live, FL Studio, Studio One, Bitwig, Cubase, and Reaper can load VST3. The setup section on this page covers the common scan paths.'
  },
  {
    question: 'Do I need an internet connection?',
    answer: 'Yes. Generations run on Sonura\'s servers so the plugin stays lightweight and the models stay up to date. You just need a regular internet connection while creating.'
  },
  {
    question: 'What can I make with the plugin?',
    answer: 'Drums and one-shots, melodic loops, basslines, vocal stems (pads, chops, ad-libs, hooks), FX, textures, and full instrumental loops. Anything from a single kick to a full melodic phrase, in any key or BPM.'
  },
  {
    question: 'How is this different from a sample pack or Splice?',
    answer: 'With a sample pack you pick from what someone else made. With Sonura Flow you describe what you need and get fresh, unique sounds matched to your track, right inside your session. No scrolling, no duplicate packs across producers.'
  },
  {
    question: 'Can I use Sonura Flow in commercial releases?',
    answer: 'Yes. Full commercial rights are included on every free and paid plan. Release on Spotify, Apple Music, YouTube, sync to video, sell beats, use in client work, the sounds are yours.'
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Sonura Flow",
    "url": "https://sonurastudio.com/plugin/",
    "downloadUrl": [MAC_URL, WIN_URL],
    "installUrl": "https://sonurastudio.com/plugin/",
    "screenshot": "https://sonurastudio.com/images/plugin-ui.webp",
    "applicationCategory": "MusicApplication",
    "applicationSubCategory": "VST3 and AU audio plugin",
    "operatingSystem": "macOS 12, Windows 10, Windows 11",
    "description": "Free VST3 and AU plugin for producers. Generate drums, vocals, loops, one-shots, and sample ideas inside Ableton, Logic Pro, FL Studio, and other major DAWs.",
    "softwareVersion": PLUGIN_VERSION,
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "featureList": [
      "VST3 and AU plugin for Mac and Windows",
      "Generated drums, loops, vocals, one-shots",
      "Runs inside Ableton Live, Logic Pro, FL Studio, Studio One, Bitwig, Cubase, Reaper, and GarageBand",
      "Royalty-free commercial rights",
      "Personal sound library",
      "Up to 4 variations per prompt"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sonurastudio.com/" },
      { "@type": "ListItem", "position": 2, "name": "Plugin", "item": "https://sonurastudio.com/plugin/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];
---

<BaseLayout
  title="Make New Sounds Inside Your DAW | Sonura Flow Plugin"
  description="Download Sonura Flow, a free VST3 and AU plugin for Mac and Windows. Generate drums, vocals, loops, one-shots, and samples inside Ableton, Logic Pro, FL Studio, and more."
  keywords="Sonura Flow, DAW plugin, VST3 plugin, AU plugin, sample generator plugin, drum generator plugin, vocal generator plugin, loop plugin, free music plugin, Ableton plugin, Logic Pro plugin, FL Studio plugin, royalty free plugin"
  canonical="https://sonurastudio.com/plugin/"
  ogTitle="Make New Sounds Inside Your DAW | Sonura Flow"
  ogDescription="Generate drums, vocals, loops, one-shots, and samples inside Ableton, Logic Pro, FL Studio, and more. VST3 and AU for Mac and Windows."
  jsonLd={jsonLd}
>

  <div class="pg">
    <div class="pg-glow"></div>
    <div class="pg-glow-b"></div>
    <div class="pg-grid"></div>

    <section class="pg-hero">
      <div class="pg-left">
        <p class="pg-kicker anim">Sonura Flow</p>
        <h1 class="anim">
          <span class="h1-row">Supercharge</span>
          <span class="h1-row h1-accent">Your DAW</span>
        </h1>

        <p class="pg-sub anim">Generate loops, drums, vocals, one-shots, and sample ideas right inside your DAW. No browser, no exporting, no file juggling.</p>

        <div class="pg-download anim" id="pg-download">
          <a class="dl-btn primary-dl" id="dl-primary" href={MAC_URL} download>
            <svg class="dl-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            <span id="dl-primary-label">Download for Mac</span>
          </a>
          <a class="dl-btn alt-dl" id="dl-alt" href={WIN_URL} download>
            <span id="dl-alt-label">Download for Windows</span>
          </a>
        </div>

        <div class="pg-os anim">
          <div class="os-badge">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <span>macOS 12+</span>
          </div>
          <div class="os-badge">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 5.548l7.065-0.964v6.817H3V5.548zm0 12.904l7.065 0.964V12.6H3v5.852zm7.937 1.048L21 20.936V12.6H10.937v6.9zM10.937 4.5L21 3.064V11.4H10.937V4.5z"/></svg>
            <span>Windows 10+</span>
          </div>
        </div>
      </div>

      <div class="pg-right anim">
        <div class="pg-stage">
          <div class="pg-halo"></div>
          <div class="pg-device">
            <div class="pg-device-bezel">
              <img src="/images/plugin-ui.webp" alt="Sonura Flow plugin interface showing loop and sound generation" width="900" height="1549" loading="eager" />
              <div class="pg-device-sheen"></div>
            </div>
          </div>
          <div class="pg-chip pg-chip-1">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
            <span>Inside your DAW</span>
          </div>
          <div class="pg-chip pg-chip-2">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>100% Royalty-Free</span>
          </div>
        </div>
      </div>
    </section>

    <section class="pg-demo anim" aria-labelledby="demo-title">
      <div class="demo-copy">
        <p class="pg-kicker">In session</p>
        <h2 id="demo-title">Create without leaving the track.</h2>
        <p>Describe the sound, generate variations, drag the result into your session, and keep writing.</p>
      </div>
      <div class="demo-frame">
        <video
          aria-label="Sonura Flow generating sounds inside a DAW session"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/videos/sonura-flow-demo-poster.jpg"
          width="900"
          height="582"
        >
          <source src="/videos/sonura-flow-demo.webm" type="video/webm" />
          <source src="/videos/sonura-flow-demo.mp4" type="video/mp4" />
        </video>
      </div>
    </section>

    <section class="pg-showcase anim">
      <header class="showcase-head">
        <h2 class="showcase-title">Your whole studio, inside your DAW.</h2>
        <p class="showcase-sub">Loops, drums, vocals, one-shots. Make them in your session, drag them onto the timeline, keep going.</p>
      </header>

      <div class="bento">
        <article class="bento-card card-drums">
          <div class="card-body">
            <h3>Make high-quality drums.</h3>
            <p>Type "techno clap" and get four clean, session-ready hits in seconds. Beats digging through sample packs for an hour.</p>
          </div>
          <div class="card-shot">
            <img src="/images/techno-clap.webp" alt="Generating a techno clap with four variations in Sonura Flow" width="800" height="1189" loading="lazy" />
          </div>
        </article>

        <article class="bento-card card-vocals">
          <div class="card-body">
            <h3>Generate vocal stems.</h3>
            <p>Describe what you want. Ethereal pads, chopped hooks, ad-libs, runs. You get usable vocal stems in seconds.</p>
          </div>
          <div class="card-shot">
            <img src="/images/make-vocals.webp" alt="Generating ethereal vocals from a text prompt" width="800" height="1371" loading="lazy" />
          </div>
        </article>

        <article class="bento-card card-library">
          <div class="card-body">
            <h3>Own your library.</h3>
            <p>Every sound you generate lands in your library. Searchable, organized, and royalty-free forever.</p>
          </div>
          <div class="card-shot">
            <img src="/images/library.webp" alt="Personal library of generated loops and one-shots" width="800" height="1222" loading="lazy" />
          </div>
        </article>

        <article class="bento-card card-multi">
          <div class="multi-body">
            <h3>Create multiple stems at once.</h3>
            <p>Hit create and get up to four variations in one go. Pick the one that works, drag it in, keep writing.</p>
          </div>
          <div class="multi-shot">
            <img src="/images/multiple-outputs.webp" alt="Four generated waveform variations side by side" width="1400" height="680" loading="lazy" />
          </div>
        </article>
      </div>
    </section>

    <section class="pg-info anim">
      <ul class="pg-features">
        <li>
          <span class="feat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
          <div>
            <strong>Create inside your DAW</strong>
            <p>Loops, one-shots, vocals, and drums without leaving the session.</p>
          </div>
        </li>
        <li>
          <span class="feat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
          <div>
            <strong>Own everything you make</strong>
            <p>Full commercial rights on every sound you generate.</p>
          </div>
        </li>
        <li>
          <span class="feat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
          <div>
            <strong>VST3 and AU</strong>
            <p>Works with any major DAW on Mac or Windows.</p>
          </div>
        </li>
        <li>
          <span class="feat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
          <div>
            <strong>Free with your plan</strong>
            <p>Included with any Sonura account. No extra subscription.</p>
          </div>
        </li>
      </ul>
      <p class="pg-daws">Ableton Live &middot; Logic Pro &middot; FL Studio &middot; Studio One &middot; Bitwig &middot; Cubase</p>
    </section>

    <section class="pg-seo anim" aria-labelledby="install-title">
      <div class="seo-head">
        <p class="pg-kicker">Setup guide</p>
        <h2 id="install-title">Install Sonura Flow in minutes.</h2>
        <p>Sonura Flow is a free VST3 and AU plugin for Mac and Windows. Install it once, sign in with your Sonura account, then create royalty-free sounds directly in your DAW session.</p>
      </div>

      <div class="seo-grid">
        <article>
          <h3>Mac install</h3>
          <ol>
            <li>Download the macOS package for Sonura Flow.</li>
            <li>Open the installer and follow the prompts.</li>
            <li>Restart your DAW so it scans the new AU and VST3 plugin.</li>
            <li>Open Sonura Flow on an audio or instrument track and sign in.</li>
          </ol>
        </article>
        <article>
          <h3>Windows install</h3>
          <ol>
            <li>Download the Windows setup file for Sonura Flow.</li>
            <li>Run the installer and keep the default VST3 location.</li>
            <li>Open your DAW plugin manager and rescan plugins.</li>
            <li>Load Sonura Flow, sign in, and start generating audio.</li>
          </ol>
        </article>
        <article>
          <h3>System requirements</h3>
          <ul>
            <li>macOS 12 Monterey or later, Apple Silicon or Intel.</li>
            <li>Windows 10 or Windows 11, 64-bit.</li>
            <li>A DAW that supports VST3 or AU plugins.</li>
            <li>An internet connection while generating sounds.</li>
          </ul>
        </article>
        <article>
          <h3>Supported DAWs</h3>
          <ul>
            <li>Ableton Live, FL Studio, Logic Pro, GarageBand, Reaper.</li>
            <li>Studio One, Bitwig Studio, Cubase, Nuendo, and more.</li>
            <li>Use AU on Logic Pro and GarageBand.</li>
            <li>Use VST3 in most other Mac and Windows DAWs.</li>
          </ul>
        </article>
      </div>
    </section>

    <section class="pg-seo pg-guides anim" aria-labelledby="guides-title">
      <div class="seo-head">
        <p class="pg-kicker">Plugin guides</p>
        <h2 id="guides-title">DAW-specific setup and workflows.</h2>
        <p>Use these guides when you want the exact plugin format, install path, and first-session workflow for your production setup.</p>
      </div>
      <div class="guide-links">
        <a href="/plugin/ableton/">Ableton Live plugin guide</a>
        <a href="/plugin/logic-pro/">Logic Pro AU plugin guide</a>
        <a href="/plugin/fl-studio/">FL Studio VST3 plugin guide</a>
        <a href="/plugin/vst3/">VST3 plugin guide</a>
        <a href="/plugin/ai-sample-generator/">Sample generator plugin</a>
        <a href="/plugin/free-vst-plugin/">Free VST plugin guide</a>
      </div>
    </section>

    <section class="pg-seo pg-troubleshooting anim" aria-labelledby="troubleshooting-title">
      <div class="seo-head">
        <p class="pg-kicker">Troubleshooting</p>
        <h2 id="troubleshooting-title">If your DAW does not see it.</h2>
        <p>Most plugin issues come down to scan settings, plugin format, or a DAW restart after install. These quick checks cover the common cases.</p>
      </div>
      <div class="seo-grid">
        <article>
          <h3>Ableton Live</h3>
          <ul>
            <li>Open Preferences, then Plug-Ins.</li>
            <li>Turn VST3 plug-in folders on.</li>
            <li>Click Rescan, then add Sonura Flow to a track.</li>
          </ul>
        </article>
        <article>
          <h3>Logic Pro and GarageBand</h3>
          <ul>
            <li>Use the AU version on macOS.</li>
            <li>Restart the app after installation.</li>
            <li>If needed, open Plug-In Manager and rescan Sonura Flow.</li>
          </ul>
        </article>
        <article>
          <h3>FL Studio</h3>
          <ul>
            <li>Open Plugin Manager.</li>
            <li>Make sure VST3 locations are enabled.</li>
            <li>Run Find Plugins, then favorite Sonura Flow.</li>
          </ul>
        </article>
        <article>
          <h3>VST3 location</h3>
          <ul>
            <li>On Windows, keep the default VST3 install path.</li>
            <li>On Mac, most DAWs scan the system VST3 folder automatically.</li>
            <li>When in doubt, restart the DAW and rescan plugins.</li>
          </ul>
        </article>
      </div>
    </section>

    <section class="pg-faq faq anim" id="faq" aria-labelledby="plugin-faq-title">
      <div class="faq-inner">
        <h2 id="plugin-faq-title" class="faq-title">Plugin FAQ</h2>
