---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqs = [
  {
    question: 'What DAWs does Sonura Flow work with?',
    answer: 'Sonura Flow is a VST3 and AU plugin, so it works with any major DAW: Ableton Live, Logic Pro, FL Studio, Studio One, Bitwig, Cubase, Reaper, GarageBand, and more. If your DAW loads VST3 or AU plugins, you can use it.'
  },
  {
    question: 'Is Sonura Flow free?',
    answer: 'Yes. The plugin is included with any Sonura account, including the free tier. Download it, sign in, and start generating sounds inside your DAW.'
  },
  {
    question: 'What operating systems are supported?',
    answer: 'Sonura Flow runs on macOS 12 Monterey or later (Apple Silicon and Intel) and Windows 10 or later (64-bit). Installers are available for both platforms on this page.'
  },
  {
    question: 'Do I own the sounds I generate?',
    answer: 'Yes. Every sound you create with Sonura Flow is fully royalty-free and yours to use forever, including in commercial releases, sync placements, streaming, and client work. No attribution required.'
  },
  {
    question: 'How do I get the sounds into my project?',
    answer: 'Sounds generated in the plugin drop straight into your DAW timeline as audio. Drag them onto a track or use the plugin\'s built-in export. No bouncing, no re-importing, no switching apps.'
  },
  {
    question: 'Do I need an internet connection?',
    answer: 'Yes. Generations run on Sonura\'s servers so the plugin stays lightweight and the models stay up to date. You just need a regular internet connection while creating.'
  },
  {
    question: 'What can I make with the plugin?',
    answer: 'Drums and one-shots, melodic loops, basslines, vocal stems (pads, chops, ad-libs, hooks), FX, textures, and full instrumental loops. Anything from a single kick to a full melodic phrase, in any key or BPM.'
  },
  {
    question: 'How is this different from a sample pack or Splice?',
    answer: 'With a sample pack you pick from what someone else made. With Sonura Flow you describe what you need and get fresh, unique sounds matched to your track, right inside your session. No scrolling, no duplicate packs across producers.'
  },
  {
    question: 'Can I use Sonura Flow in commercial releases?',
    answer: 'Yes. Full commercial rights are included on every free and paid plan. Release on Spotify, Apple Music, YouTube, sync to video, sell beats, use in client work, the sounds are yours.'
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Sonura Flow",
    "url": "https://sonurastudio.com/plugin/",
    "applicationCategory": "MultimediaApplication",
    "applicationSubCategory": "Audio Plugin",
    "operatingSystem": "macOS 12, Windows 10, Windows 11",
    "description": "Free AI plugin for producers. Generate drums, vocals, loops, and one-shots inside your DAW. VST3 and AU. Royalty-free.",
    "softwareVersion": "1.1.1",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "ratingCount": "127"
    },
    "featureList": [
      "VST3 and AU plugin",
      "AI-generated drums, loops, vocals, one-shots",
      "Runs inside any major DAW",
      "Royalty-free commercial rights",
      "Personal sound library",
      "Up to 4 variations per prompt"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sonurastudio.com/" },
      { "@type": "ListItem", "position": 2, "name": "Plugin", "item": "https://sonurastudio.com/plugin/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];
---

