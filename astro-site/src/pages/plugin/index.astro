<script define:vars={{ PLUGIN_VERSION, MAC_URL, WIN_URL, WIN_ZIP_URL, MANIFEST_URL: PLUGIN_MANIFEST_URL, VERSION_API_URL: PLUGIN_VERSION_API_URL }}>
  // @ts-nocheck
  // Keep the displayed version in sync with the latest published plugin without a
  // site rebuild: the build-time value is the fallback. The backend endpoint is the
  // primary source because the R2 manifest blocks cross-origin reads.
  (async () => {
    const apply = (version) => {
      if (typeof version !== 'string' || !version) return false;
      const label = 'Version ' + version.replace(/^v/, '');
      document.querySelectorAll('.plugin-version-label').forEach((el) => { el.textContent = label; });
      return true;
    };
    try {
      const res = await fetch(VERSION_API_URL, { cache: 'no-store' });
      if (res.ok && apply((await res.json())?.version)) return;
    } catch {}
    try {
      const res = await fetch(MANIFEST_URL, { cache: 'no-store' });
      if (res.ok) apply((await res.json())?.version);
    } catch {}
  })();

  const isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform) || /Macintosh/.test(navigator.userAgent);

  const getDownloadUrl = (platform, packageType = 'installer') => {
    if (platform === 'mac') return MAC_URL;
    return packageType === 'zip' ? WIN_ZIP_URL : WIN_URL;
  };

  const getFileExtension = (platform, packageType = 'installer') => {
    if (platform === 'mac') return 'pkg';
    return packageType === 'zip' ? 'zip' : 'exe';
  };

  const trackDownload = (platform, location, button, packageType = 'installer') => {
    const url = getDownloadUrl(platform, packageType);
    const fileName = url.split('/').pop();
    const fileExtension = getFileExtension(platform, packageType);

    if (typeof window.gtag === 'function') {
      window.gtag('event', 'plugin_download', {
        plugin_platform: platform,
        plugin_version: PLUGIN_VERSION,
        plugin_location: location,
        plugin_button: button,
        plugin_package: packageType,
        file_name: fileName,
        file_extension: fileExtension,
        link_url: url,
        transport_type: 'beacon',
      });
      window.gtag('event', 'file_download', {
        file_name: fileName,
        file_extension: fileExtension,
        link_url: url,
        transport_type: 'beacon',
      });
    }

    if (typeof window.fbq === 'function') {
      window.fbq('trackCustom', 'PluginDownload', {
        platform,
        version: PLUGIN_VERSION,
        location,
        button,
        package: packageType,
      });
      window.fbq('track', 'Lead', {
        content_name: 'Sonura Flow Plugin',
        content_category: platform,
      });
    }

    if (typeof window.dataLayer !== 'undefined') {
      window.dataLayer.push({
        event: 'plugin_download',
        plugin_platform: platform,
        plugin_version: PLUGIN_VERSION,
        plugin_location: location,
        plugin_button: button,
        plugin_package: packageType,
      });
    }
  };

  const closeDownloadMenus = () => {
    document.querySelectorAll('.dl-choice.is-open').forEach((choice) => {
      choice.classList.remove('is-open');
      choice.querySelector('.dl-btn')?.setAttribute('aria-expanded', 'false');
    });
  };

  const setupDownloadSlot = (button, label, choice, menu, platform, location, buttonName) => {
    if (!button || !label || !choice || !menu) return;

    const isWindows = platform === 'windows';
    choice.classList.toggle('is-windows', isWindows);
    button.href = getDownloadUrl(platform);
    label.textContent = isWindows ? 'Download for Windows' : 'Download for Mac';
    button.setAttribute('aria-haspopup', isWindows ? 'menu' : 'false');
    button.setAttribute('aria-expanded', 'false');

    button.addEventListener('click', (event) => {
      if (!isWindows) {
        trackDownload(platform, location, buttonName);
        return;
      }

      event.preventDefault();
      const wasOpen = choice.classList.contains('is-open');
      closeDownloadMenus();
      choice.classList.toggle('is-open', !wasOpen);
      button.setAttribute('aria-expanded', String(!wasOpen));
    });

    menu.querySelectorAll('[data-download-option]').forEach((option) => {
      option.addEventListener('click', () => {
        trackDownload('windows', location, buttonName, option.dataset.downloadOption);
        closeDownloadMenus();
      });
    });
  };

  const setupDownload = (primaryId, primaryLabelId, primaryChoiceId, primaryMenuId, altId, altLabelId, altChoiceId, altMenuId, location) => {
    const primaryBtn = document.getElementById(primaryId);
    const primaryLabel = document.getElementById(primaryLabelId);
    const primaryChoice = document.getElementById(primaryChoiceId);
    const primaryMenu = document.getElementById(primaryMenuId);
    const altBtn = document.getElementById(altId);
    const altLabel = document.getElementById(altLabelId);
    const altChoice = document.getElementById(altChoiceId);
    const altMenu = document.getElementById(altMenuId);
    if (!primaryBtn || !altBtn) return;

    const primaryPlatform = isMac ? 'mac' : 'windows';
    const altPlatform = isMac ? 'windows' : 'mac';

    setupDownloadSlot(primaryBtn, primaryLabel, primaryChoice, primaryMenu, primaryPlatform, location, 'primary');
    setupDownloadSlot(altBtn, altLabel, altChoice, altMenu, altPlatform, location, 'alt');
  };

  setupDownload('dl-primary', 'dl-primary-label', 'dl-primary-choice', 'dl-primary-menu', 'dl-alt', 'dl-alt-label', 'dl-alt-choice', 'dl-alt-menu', 'hero');
  setupDownload('dl-primary-b', 'dl-primary-label-b', 'dl-primary-choice-b', 'dl-primary-menu-b', 'dl-alt-b', 'dl-alt-label-b', 'dl-alt-choice-b', 'dl-alt-menu-b', 'cta');

  document.addEventListener('click', (event) => {
    if (!event.target.closest('.dl-choice')) closeDownloadMenus();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeDownloadMenus();
  });

  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap === 'undefined') return;

    const items = document.querySelectorAll('.anim');
    gsap.set(items, { opacity: 0, y: 30 });
    gsap.to(items, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power3.out',
      stagger: 0.1,
      delay: 0.15,
    });

    const device = document.querySelector('.pg-device');
    if (device) {
      gsap.set(device, { rotateY: 10, rotateX: -4, scale: 0.94 });
      gsap.to(device, {
        rotateY: 0,
        rotateX: 0,
        scale: 1,
        duration: 1.3,
        ease: 'power3.out',
        delay: 0.3,
      });

      gsap.to(device, {
        y: -12,
        duration: 3.5,
        ease: 'sine.inOut',
        yoyo: true,
        repeat: -1,
        delay: 1.6,
      });
    }

    const chip1 = document.querySelector('.pg-chip-1');
    const chip2 = document.querySelector('.pg-chip-2');
    if (chip1) {
      gsap.set(chip1, { opacity: 0, x: -20 });
      gsap.to(chip1, {
        opacity: 1,
        x: 0,
        duration: 0.6,
        ease: 'power2.out',
        delay: 0.9,
        onComplete: () => {
          gsap.to(chip1, {
            y: -14,
            x: 6,
            rotate: -1.5,
            duration: 4.2,
            ease: 'sine.inOut',
            yoyo: true,
            repeat: -1,
          });
        },
      });
    }
    if (chip2) {
      gsap.set(chip2, { opacity: 0, x: 20 });
      gsap.to(chip2, {
        opacity: 1,
        x: 0,
        duration: 0.6,
        ease: 'power2.out',
        delay: 1.1,
        onComplete: () => {
          gsap.to(chip2, {
            y: 12,
            x: -6,
            rotate: 1.5,
            duration: 5,
            ease: 'sine.inOut',
            yoyo: true,
            repeat: -1,
            delay: 0.4,
          });
        },
      });
    }

    const features = document.querySelectorAll('.pg-features li');
    if (features.length) {
      gsap.set(features, { opacity: 0, y: 16 });
      gsap.to(features, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: 'power2.out',
        stagger: 0.08,
        delay: 0.6,
      });
    }

    const faqItems = document.querySelectorAll('.pg-faq details');
    if (faqItems.length && typeof ScrollTrigger !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);
      gsap.set(faqItems, { opacity: 0, y: 20 });
      gsap.to(faqItems, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: 'power2.out',
        stagger: 0.05,
        scrollTrigger: {
          trigger: '.pg-faq',
          start: 'top 80%',
          once: true,
        },
      });
    }

    const bentoCards = document.querySelectorAll('.bento-card');
    if (bentoCards.length && typeof ScrollTrigger !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);
      gsap.set(bentoCards, { opacity: 0, y: 40 });
      gsap.to(bentoCards, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: 'power3.out',
        stagger: 0.09,
        scrollTrigger: {
          trigger: '.pg-showcase',
          start: 'top 75%',
          once: true,
        },
      });
    } else if (bentoCards.length) {
      gsap.set(bentoCards, { opacity: 0, y: 40 });
      gsap.to(bentoCards, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: 'power3.out',
        stagger: 0.09,
        delay: 0.5,
      });
    }
  });
</script>

