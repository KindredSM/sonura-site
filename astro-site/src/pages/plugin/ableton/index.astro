const relatedGuides = [
  { title: 'Logic Pro AU plugin guide', href: '/plugin/logic-pro/', description: 'Install Sonura Flow as an AU plugin in Logic Pro and GarageBand.' },
  { title: 'FL Studio VST3 plugin guide', href: '/plugin/fl-studio/', description: 'Load Sonura Flow from the FL Studio plugin manager.' },
