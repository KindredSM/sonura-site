---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import newThumbnail from '../../assets/images/new-thumbnail.jpg';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Sonura",
    "url": "https://sonurastudio.com/",
    "logo": "https://sonurastudio.com/demo-image.jpeg",
    "description": "Sonura is the AI studio for original audio. Create royalty-free music, loops, vocals, stems, one-shots, and sound effects in one place.",
    "founder": [
      {
        "@type": "Person",
        "name": "Kindred Salway",
        "jobTitle": "Co-founder",
        "sameAs": "https://www.linkedin.com/in/kindred-salway-8a05b6240/"
      },
      {
        "@type": "Person",
        "name": "Blue Bookhard",
        "jobTitle": "Co-founder"
      }
    ],
    "sameAs": [
      "https://twitter.com/sonurastudio",
      "https://discord.gg/Yk8RD3Nmyh",
      "https://www.linkedin.com/in/kindred-salway-8a05b6240/"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "kindred@sonurastudio.com",
      "contactType": "Customer Support"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About Sonura",
    "description": "Learn about Sonura, the AI studio for original audio. Our mission is to accelerate music, sound design, and audio creation through AI without replacing the creative process.",
    "mainEntity": {
      "@type": "Organization",
      "name": "Sonura"
    }
  }
];
---

<BaseLayout
  title="About Sonura | The Studio for Original Audio"
  description="Sonura is the studio for original audio. Create royalty-free music, loops, vocals, stems, one-shots, and sound effects in one place. Built for producers, artists, sound designers, and creators."
  keywords="sonura about, ai music company, ai audio company, sound design startup, kindred salway, ai sound generator company"
  canonical="https://sonurastudio.com/about/"
  ogTitle="About Sonura - The Studio for Original Audio"
  ogDescription="The studio for original audio. Learn about Sonura's mission and the team behind it."
  jsonLd={jsonLd}
>
  <section class="about-hero">
    <div class="about-hero-inner">
      <h1 class="about-headline reveal">Sounds that don't exist yet</h1>
      <p class="about-subhead reveal" data-reveal-delay="0.04s">Everyone pulls from the same packs. Sonura makes new sounds instead: original audio you can shape in seconds, and every creative decision stays yours.</p>
    </div>
  </section>

  <section class="about-section mission-section">
    <div class="about-section-inner">
      <div class="mission-grid">
        <div class="mission-content reveal">
          <p class="section-kicker">01 / Mission</p>
          <h2 class="section-title">The Problem</h2>
          <p class="section-text">Audio creation has been gatekept by expensive gear, years of technical training, and software with steep learning curves. Creators who need original sound are forced to overpay for custom work or settle for generic stock audio that thousands of others are already using.</p>
          <p class="section-text">The demand for distinctive music, sound effects, stems, samples, and branded audio is growing across every industry. Traditional workflows can't keep up.</p>
        </div>
        <div class="mission-visual synth-panel reveal" data-reveal-delay="0.08s">
          <div class="mission-stats">
            <div class="mission-stat">
              <span class="stat-number">10s</span>
              <span class="stat-label">avg creation time</span>
            </div>
            <div class="mission-stat">
              <span class="stat-number">100%</span>
              <span class="stat-label">royalty-free ownership</span>
            </div>
            <div class="mission-stat">
              <span class="stat-number">Endless</span>
              <span class="stat-label">unique creations</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section solution-section">
    <div class="about-section-inner">
      <div class="solution-grid">
        <div class="solution-content reveal">
          <p class="section-kicker">02 / Approach</p>
          <h2 class="section-title">What Sonura Does</h2>
          <p class="section-text">Sonura turns text descriptions into studio-quality music, loops, vocals, one-shots, sound effects, and full tracks. It's designed for rapid iteration: create, refine, export stems, and keep moving. Professional-grade audio without the traditional overhead.</p>
          <p class="section-text">Whether you're scoring a game, building a sample library, designing sounds for a video, producing your next release, or creating content, Sonura adapts to your workflow.</p>
          
          <div class="target-audience">
            <h3 class="audience-title">Built for</h3>
            <div class="audience-text">
              <p>Producers | Artists | Songwriters | Composers | Sound Designers | Content Creators | Game Developers | Filmmakers</p>
            </div>
          </div>
        </div>
        <div class="solution-visual reveal" data-reveal-delay="0.08s">
          <div class="industry-context synth-panel">
            <div class="context-content">
              <h3 class="context-title">Our Approach</h3>
              <p class="context-text">Sonura is designed to extend your imagination and speed up your process, not to replace the creative decisions that make sound and music human.</p>
              <p class="context-text">We're building tools that keep musicians and audio creators in control, with command over every stem, layer, texture, and detail.</p>
              <p class="context-text">We're also built on the consent side of AI music: licensed, not scraped. Tools trained on scraped catalogs are in court over it, and what you make with them sits on shaky commercial ground. What you make here is cleared to release and sell. <a href="/how-we-work-with-artists/" class="text-link">See how we work with artists</a>.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section product-section">
    <div class="about-section-inner">
      <p class="section-kicker">03 / Product</p>
      <div class="product-header reveal">
        <h2 class="section-title">Our Product</h2>
        <div class="product-stage">
          <span class="stage-text">Fully Launched & Live</span>
        </div>
      </div>
      
      <div class="product-grid">
        <div class="product-image synth-panel reveal" data-reveal-delay="0.04s">
          <Image 
            src={newThumbnail}
            alt="Sonura Music Generator Interface"
            style="width: 100%; height: auto; display: block;"
          />
        </div>
        
        <div class="product-features reveal" data-reveal-delay="0.08s">
          <div class="feature-item">
            <div class="feature-content">
              <h4>Text-to-Audio</h4>
              <p>Describe a sound and get professional music, loops, or FX in seconds</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-content">
              <h4>Stem Export</h4>
              <p>Separate drums, bass, melody, FX, and vocals for your DAW or edit</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-content">
              <h4>AI Vocals, One-Shots & FX</h4>
              <p>Create original vocals, one-shots, textures, and sound effects on demand</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-content">
              <h4>Community & Remixing</h4>
              <p>Share tracks and stems that other creators can remix directly</p>
            </div>
          </div>
          <a href="/features/" class="features-link">Explore all features -></a>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section team-section" id="founders">
    <div class="about-section-inner">
      <p class="section-kicker">04 / Founders</p>
      <h2 class="section-title center reveal">Meet the Founders</h2>
      
      <div class="team-grid">
        <div class="founder-card reveal" data-reveal-delay="0.04s">
          <div class="founder-content">
            <div class="founder-image">
              <img src="/images/kindred.jpg" alt="Kindred Salway - Co-founder of Sonura" />
            </div>
            <div class="founder-info">
              <h3 class="founder-name">Kindred Salway</h3>
              <span class="founder-role">Co-founder and CEO</span>
              
              <div class="founder-bio">
                <p>Kindred is a music technologist, producer, and engineer with a background in audio and software. He studied music technology, co-founded Bleached, engineered sound for AudioActive FM, and started Sonura to make original audio faster to sketch, shape, and finish without giving up creative control.</p>
              </div>
              
              <div class="founder-links">
                <a href="https://x.com/kindredsalway" target="_blank" rel="noopener" class="linkedin-link">
                  Follow on X (Twitter)
                </a>
                <span class="separator">|</span>
                <a href="https://www.linkedin.com/in/kindred-salway-8a05b6240/" target="_blank" rel="noopener" class="linkedin-link">
                  Connect on LinkedIn
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="founder-card reveal" data-reveal-delay="0.08s">
          <div class="founder-content">
            <div class="founder-image founder-image-static">
              <img src="/images/blue.jpg" alt="Blue Bookhard - Co-founder of Sonura" />
            </div>
            <div class="founder-info">
              <h3 class="founder-name">Blue Bookhard</h3>
              <span class="founder-role">Co-founder and COO</span>
              
              <div class="founder-bio">
                <p>Blue is a creator and growth operator across music, creators, and major platforms. He led creator marketing at Snapchat, was Head of Pop at TIDAL, worked in partner marketing at Google, earned an MBA from London Business School, and runs No Skips, a music publication reaching 40,000 monthly readers.</p>
              </div>

              <div class="founder-links">
                <a href="https://www.instagram.com/iambluetyler/" target="_blank" rel="noopener" class="linkedin-link">
                  Follow on Instagram
                </a>
                <span class="separator">|</span>
                <a href="https://www.linkedin.com/in/bluebookhard/" target="_blank" rel="noopener" class="linkedin-link">
                  Connect on LinkedIn
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section contact-section">
    <div class="about-section-inner">
      <div class="contact-card reveal">
        <p class="section-kicker">05 / Contact</p>
        <h2 class="contact-title">Get in Touch</h2>
        <p class="contact-text">Questions, partnerships, or feedback. We're always listening.</p>
        <div class="contact-actions">
          <a href="mailto:kindred@sonurastudio.com" class="text-link">kindred@sonurastudio.com</a>
          <span class="separator">|</span>
          <a href="https://discord.gg/Yk8RD3Nmyh" target="_blank" rel="noopener" class="text-link">Join our Discord</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding: clamp(96px, 14vh, 180px) var(--page-pad) clamp(72px, 9vw, 120px);
    text-align: left;
    position: relative;
  }

  .about-hero-inner {
    max-width: 1100px;
    margin: 0;
  }

  .about-headline {
    font-family: var(--font-display);
    font-size: clamp(48px, 7vw, 104px);
    line-height: 0.96;
    margin: 0 0 32px;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    font-weight: 400;
    color: var(--fg);
    text-align: left;
  }

  .about-subhead {
    font-size: 17px;
    color: var(--muted);
    line-height: 1.8;
    letter-spacing: 0.022em;
    word-spacing: 0.04em;
    text-transform: lowercase;
    margin: 0;
    max-width: 640px;
    font-weight: 400;
    text-align: left;
  }

  .about-section {
    padding: clamp(72px, 9vw, 110px) var(--page-pad);
    border-top: 1px solid var(--hairline);
  }

  .about-section-inner {
    max-width: none;
    margin: 0;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(38px, 4.8vw, 68px);
    letter-spacing: 0.01em;
    text-transform: uppercase;
    line-height: 1;
    margin: 0 0 32px;
    font-weight: 400;
    color: var(--fg);
  }

  .section-title.center {
    text-align: left;
    margin-bottom: 64px;
  }

  .section-text {
    font-size: clamp(16px, 2vw, 18px);
    color: var(--muted);
    line-height: 1.8;
    margin: 0 0 24px;
    max-width: 760px;
  }

  .section-text:last-of-type {
    margin-bottom: 0;
  }

  .mission-grid,
  .solution-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .mission-visual,
  .solution-visual {
    padding: 64px;
    background: var(--panel-bg);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-panel);
    box-shadow: none;
    position: relative;
  }

  .mission-stats {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .mission-stat {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 64px);
    font-weight: 400;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--fg);
    line-height: 1;
  }

  .stat-label {
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 500;
  }

  .target-audience {
    margin-top: 48px;
    padding-top: 48px;
    border-top: 1px solid var(--border);
  }

  .audience-title {
    font-size: 13px;
    font-weight: 700;
    margin: 0 0 16px;
    color: var(--fg);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .audience-text p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.8;
    margin: 0;
  }

  .industry-context {
    padding: 0;
    background: transparent;
    border: none;
    box-shadow: none;
  }

  .context-title {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 24px;
    color: var(--fg);
  }

  .context-text {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 16px;
    text-transform: lowercase;
    letter-spacing: 0.022em;
    line-height: 1.8;
  }

  .product-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 64px;
    border-bottom: 1px solid var(--hairline);
    padding-bottom: 24px;
  }

  .product-stage {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .stage-text {
    font-size: 12px;
    color: var(--muted);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .product-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr;
    gap: 64px;
    align-items: start;
  }

  .product-image {
    position: relative;
    background: var(--panel-bg);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-panel);
    padding: 12px; /* Inner frame padding */
  }

  .product-image img {
    display: block;
    width: 100%;
    height: auto;
    filter: contrast(1.05);
    transition: filter 0.5s ease;
  }
  
  .product-image:hover img {
    filter: contrast(1.05);
  }

  .product-features {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding-top: 24px;
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .feature-content h4 {
    margin: 0 0 8px;
    font-size: 13px;
    font-weight: 700;
    color: var(--fg);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .feature-content p {
    margin: 0;
    font-size: 15px;
    color: var(--muted);
    line-height: 1.6;
  }

  .features-link {
    display: inline-block;
    color: var(--fg);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    margin-top: 16px;
    border-bottom: 1px solid var(--hairline);
    padding-bottom: 2px;
    align-self: flex-start;
    transition: border-color 0.2s, color 0.2s;
  }

  .features-link:hover {
    color: var(--fg);
    border-color: var(--fg);
  }

  .team-grid {
    max-width: 980px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 96px;
  }

  .founder-card {
    background: transparent; /* Removed panel bg */
    padding: 0; /* Removed padding */
  }

  .founder-content {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 64px;
    align-items: start;
  }

  .founder-image {
    width: 100%;
    aspect-ratio: 1;
    border-radius: var(--radius-panel);
    border: 1px solid var(--hairline);
    overflow: hidden;
    filter: grayscale(100%);
    transition: filter 0.5s ease;
  }
  
  .founder-image:hover {
    filter: grayscale(0%);
  }

  .founder-image-static:hover {
    filter: grayscale(100%);
  }

  .founder-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .founder-info {
    padding-top: 12px;
  }

  .founder-name {
    font-family: var(--font-display);
    font-size: clamp(24px, 2.8vw, 38px);
    font-weight: 400;
    margin: 0 0 8px;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    line-height: 1;
    color: var(--fg);
  }

  .founder-role {
    display: block;
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 32px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 500;
  }

  .founder-bio {
    text-align: left;
  }

  .founder-bio p {
    font-size: 16px;
    color: var(--fg);
    line-height: 1.7;
    margin: 0 0 18px;
  }

  .founder-bio p:last-child {
    margin-bottom: 0;
  }

  .founder-links {
    margin-top: 24px;
    display: flex;
    gap: 16px;
    align-items: center;
    justify-content: flex-start;
  }

  .linkedin-link {
    display: inline-block;
    color: var(--fg);
    font-size: 14px;
    font-weight: 600;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 7px;
    text-decoration-color: currentColor;
  }

  .contact-section {
    padding-bottom: 160px;
  }

  .contact-card {
    max-width: 800px;
    margin: 0;
    text-align: left;
    padding: 0;
    background: transparent;
    border: none;
  }

  .contact-title {
    font-family: var(--font-display);
    font-size: clamp(38px, 4.8vw, 68px);
    margin: 0 0 24px;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    line-height: 1;
    font-weight: 400;
    color: var(--fg);
  }

  .contact-text {
    font-size: 17px;
    color: var(--muted);
    margin: 0 0 48px;
    line-height: 1.8;
    letter-spacing: 0.022em;
    word-spacing: 0.04em;
    text-transform: lowercase;
  }

  .contact-actions {
    display: flex;
    gap: 16px;
    justify-content: flex-start;
    align-items: center;
    font-size: 18px;
  }


  .separator {
    color: var(--faint);
  }

  @media (max-width: 900px) {
    .mission-grid,
    .solution-grid,
    .product-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    
    .product-grid {
      display: flex;
      flex-direction: column-reverse;
    }

    .founder-content {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .founder-image {
      width: 200px;
      margin: 0;
    }

    .founder-info {
      text-align: left;
    }

    .founder-bio {
      text-align: left;
    }
  }

  @media (max-width: 768px) {
    .about-hero {
      padding: 96px var(--page-pad) 72px;
    }

    .about-section {
      padding: 64px var(--page-pad);
    }

    .mission-visual,
    .solution-visual {
      padding: 32px;
    }

    .product-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
    
    .contact-actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .founder-links {
      flex-direction: column;
      gap: 20px;
      align-items: flex-start;
    }
    
    .separator { display: none; }
  }
</style>
