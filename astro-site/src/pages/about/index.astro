---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import newThumbnail from '../../assets/images/new-thumbnail.jpg';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Sonura",
    "url": "https://sonurastudio.com/",
    "logo": "https://sonurastudio.com/demo-image.jpeg",
    "description": "Sonura is the AI studio for original audio. Create royalty-free music, loops, vocals, stems, one-shots, and sound effects in one place.",
    "founder": [
      {
        "@type": "Person",
        "name": "Kindred Salway",
        "jobTitle": "Co-founder",
        "sameAs": "https://www.linkedin.com/in/kindred-salway-8a05b6240/"
      },
      {
        "@type": "Person",
        "name": "Blue Bookhard",
        "jobTitle": "Co-founder"
      }
    ],
    "sameAs": [
      "https://twitter.com/sonurastudio",
      "https://discord.gg/Yk8RD3Nmyh",
      "https://www.linkedin.com/in/kindred-salway-8a05b6240/"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "kindred@sonurastudio.com",
      "contactType": "Customer Support"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About Sonura",
    "description": "Learn about Sonura, the AI studio for original audio. Our mission is to accelerate music, sound design, and audio creation through AI without replacing the creative process.",
    "mainEntity": {
      "@type": "Organization",
      "name": "Sonura"
    }
  }
];
---

<BaseLayout
  title="About Sonura | The AI Studio for Audio Creation"
  description="Sonura is the AI studio for original audio. Create royalty-free music, loops, vocals, stems, one-shots, and sound effects in one place. Built for producers, artists, sound designers, and creators."
  keywords="sonura about, ai music company, ai audio company, sound design startup, kindred salway, ai sound generator company"
  canonical="https://sonurastudio.com/about/"
  ogTitle="About Sonura - The AI Studio for Audio Creation"
  ogDescription="The AI studio for original audio. Learn about Sonura's mission and the team behind it."
  jsonLd={jsonLd}
>
  <section class="about-hero">
    <div class="about-hero-inner">
      <h1 class="about-headline reveal">Original audio, without the friction</h1>
      <p class="about-subhead reveal" data-reveal-delay="0.04s">Sonura gives creators and professionals the tools to make music, sound design, vocals, loops, and sonic ideas at the speed of thought, without replacing the human spark that drives them.</p>
    </div>
  </section>

  <section class="about-section mission-section">
    <div class="about-section-inner">
      <div class="mission-grid">
        <div class="mission-content reveal">
          <h2 class="section-title">The Problem</h2>
          <p class="section-text">Audio creation has been gatekept by expensive gear, years of technical training, and software with steep learning curves. Creators who need original sound are forced to overpay for custom work or settle for generic stock audio that thousands of others are already using.</p>
          <p class="section-text">The demand for distinctive music, sound effects, stems, samples, and branded audio is growing across every industry. Traditional workflows can't keep up.</p>
        </div>
        <div class="mission-visual synth-panel reveal" data-reveal-delay="0.08s">
          <div class="mission-stats">
            <div class="mission-stat">
              <span class="stat-number">10s</span>
              <span class="stat-label">avg generation time</span>
            </div>
            <div class="mission-stat">
              <span class="stat-number">100%</span>
              <span class="stat-label">royalty-free ownership</span>
            </div>
            <div class="mission-stat">
              <span class="stat-number">Endless</span>
              <span class="stat-label">unique creations</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section solution-section">
    <div class="about-section-inner">
      <div class="solution-grid">
        <div class="solution-content reveal">
          <h2 class="section-title">What Sonura Does</h2>
          <p class="section-text">Sonura turns text descriptions into studio-quality music, loops, vocals, one-shots, sound effects, and full tracks. It's designed for rapid iteration: generate, refine, export stems, and keep moving. Professional-grade audio without the traditional overhead.</p>
          <p class="section-text">Whether you're scoring a game, building a sample library, designing sounds for a video, producing your next release, or creating content, Sonura adapts to your workflow.</p>
          
          <div class="target-audience">
            <h3 class="audience-title">Built for</h3>
            <div class="audience-text">
              <p>Producers | Artists | Songwriters | Composers | Sound Designers | Content Creators | Game Developers | Filmmakers</p>
            </div>
          </div>
        </div>
        <div class="solution-visual reveal" data-reveal-delay="0.08s">
          <div class="industry-context synth-panel">
            <div class="context-content">
              <h3 class="context-title">Our Approach</h3>
              <p class="context-text">Sonura is designed to extend your imagination and speed up your process, not to replace the creative decisions that make sound and music human.</p>
              <p class="context-text">We're building tools that keep musicians and audio creators ahead in the AI era, giving professionals full control over every stem, layer, texture, and detail.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section product-section">
    <div class="about-section-inner">
      <div class="product-header reveal">
        <h2 class="section-title">Our Product</h2>
        <div class="product-stage">
          <span class="stage-text">Fully Launched & Live</span>
        </div>
      </div>
      
      <div class="product-grid">
        <div class="product-image synth-panel reveal" data-reveal-delay="0.04s">
          <Image 
            src={newThumbnail}
            alt="Sonura AI Music Generator Interface" 
            style="width: 100%; height: auto; display: block;"
          />
        </div>
        
        <div class="product-features reveal" data-reveal-delay="0.08s">
          <div class="feature-item">
            <div class="feature-content">
              <h4>Text-to-Audio</h4>
              <p>Describe a sound and get professional music, loops, or FX in seconds</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-content">
              <h4>Stem Export</h4>
              <p>Separate drums, bass, melody, FX, and vocals for your DAW or edit</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-content">
              <h4>AI Vocals, One-Shots & FX</h4>
              <p>Generate original vocals, one-shots, textures, and sound effects on demand</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-content">
              <h4>Community & Remixing</h4>
              <p>Share tracks and stems that other creators can remix directly</p>
            </div>
          </div>
          <a href="/features/" class="features-link">Explore all features -></a>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section team-section" id="founders">
    <div class="about-section-inner">
      <h2 class="section-title center reveal">Meet the Founders</h2>
      
      <div class="team-grid">
        <div class="founder-card reveal" data-reveal-delay="0.04s">
          <div class="founder-content">
            <div class="founder-image">
              <img src="/images/kindred.jpg" alt="Kindred Salway - Co-founder of Sonura" />
            </div>
            <div class="founder-info">
              <h3 class="founder-name">Kindred Salway</h3>
              <span class="founder-role">Co-founder and CEO</span>
              
              <div class="founder-bio">
                <p>Kindred is a music technologist, producer, and engineer with a background in audio and software. He studied music technology, co-founded Bleached, engineered sound for AudioActive FM, and started Sonura to make original audio faster to sketch, shape, and finish without giving up creative control.</p>
              </div>
              
              <div class="founder-links">
                <a href="https://x.com/kindredsalway" target="_blank" rel="noopener" class="linkedin-link">
                  Follow on X (Twitter)
                </a>
                <span class="separator">|</span>
                <a href="https://www.linkedin.com/in/kindred-salway-8a05b6240/" target="_blank" rel="noopener" class="linkedin-link">
                  Connect on LinkedIn
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="founder-card reveal" data-reveal-delay="0.08s">
          <div class="founder-content">
            <div class="founder-image">
              <img src="/images/blue.jpg" alt="Blue Bookhard - Co-founder of Sonura" />
            </div>
            <div class="founder-info">
              <h3 class="founder-name">Blue Bookhard</h3>
              <span class="founder-role">Co-founder and GTM Lead</span>
              
              <div class="founder-bio">
                <p>Blue is a creator and growth operator across music, creators, and major platforms. He led creator marketing at Snapchat, was Head of Pop at TIDAL, worked in partner marketing at Google, earned an MBA from London Business School, and runs No Skips, a music publication reaching 40,000 monthly readers.</p>
              </div>

              <div class="founder-links">
                <a href="https://www.instagram.com/iambluetyler/" target="_blank" rel="noopener" class="linkedin-link">
                  Follow on Instagram
                </a>
                <span class="separator">|</span>
                <a href="https://www.linkedin.com/in/bluebookhard/" target="_blank" rel="noopener" class="linkedin-link">
                  Connect on LinkedIn
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section contact-section">
    <div class="about-section-inner">
      <div class="contact-card reveal">
        <h2 class="contact-title">Get in Touch</h2>
        <p class="contact-text">Questions, partnerships, or feedback. We're always listening.</p>
        <div class="contact-actions">
          <a href="mailto:kindred@sonurastudio.com" class="text-link">kindred@sonurastudio.com</a>
          <span class="separator">|</span>
          <a href="https://discord.gg/Yk8RD3Nmyh" target="_blank" rel="noopener" class="text-link">Join our Discord</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding: 180px 24px 120px;
    text-align: center;
    position: relative;
  }

  .about-hero-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .about-headline {
    font-size: clamp(42px, 7vw, 72px);
    line-height: 1.05;
    margin: 0 0 32px;
    letter-spacing: -0.04em;
    font-weight: 700;
    color: var(--fg);
    text-align: center;
  }

  .about-subhead {
    font-size: clamp(18px, 2.5vw, 24px);
    color: var(--muted);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 720px;
    font-weight: 400;
    text-align: center;
  }

  .about-section {
    padding: 100px 24px;
  }

  .about-section-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-title {
    font-size: clamp(32px, 5vw, 42px);
    letter-spacing: -0.03em;
    margin: 0 0 32px;
    font-weight: 700;
    color: var(--fg);
  }

  .section-title.center {
    text-align: center;
    margin-bottom: 64px;
  }

  .section-text {
    font-size: clamp(16px, 2vw, 18px);
    color: var(--muted);
    line-height: 1.8;
    margin: 0 0 24px;
  }

  .section-text:last-of-type {
    margin-bottom: 0;
  }

  .mission-grid,
  .solution-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .mission-visual,
  .solution-visual {
    padding: 64px;
    background: var(--panel-bg);
    border: 1px solid var(--border);
    border-radius: 2px;
    box-shadow: 0 20px 40px -20px rgba(0,0,0,0.5);
    position: relative;
  }

  /* Refined corner accents instead of screws for text panels */
  .mission-visual::before,
  .solution-visual::before,
  .product-image::before {
    content: '';
    position: absolute;
    top: -1px;
    left: -1px;
    width: 20px;
    height: 20px;
    border-top: 2px solid var(--border-light);
    border-left: 2px solid var(--border-light);
    opacity: 0.5;
  }

  .mission-visual::after,
  .solution-visual::after,
  .product-image::after {
    content: '';
    position: absolute;
    bottom: -1px;
    right: -1px;
    width: 20px;
    height: 20px;
    border-bottom: 2px solid var(--border-light);
    border-right: 2px solid var(--border-light);
    opacity: 0.5;
  }
  
  /* Hide the purple screws */
  .screw { display: none; }

  .mission-stats {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .mission-stat {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .stat-number {
    font-size: clamp(48px, 6vw, 64px);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--fg);
    line-height: 1;
  }

  .stat-label {
    font-size: 13px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
    opacity: 0.7;
  }

  .target-audience {
    margin-top: 48px;
    padding-top: 48px;
    border-top: 1px solid var(--border);
  }

  .audience-title {
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 16px;
    color: var(--fg);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .audience-text p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.8;
    margin: 0;
  }

  .industry-context {
    padding: 0;
    background: transparent;
    border: none;
    box-shadow: none;
  }

  .industry-context::before, .industry-context::after {
    display: none;
  }

  .context-title {
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 24px;
    color: var(--fg);
    letter-spacing: -0.02em;
  }

  .context-text {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 16px;
  }

  .product-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 64px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 24px;
  }

  .product-stage {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .stage-text {
    font-size: 14px;
    color: var(--fg); /* Changed from accent to fg */
    font-weight: 500;
    letter-spacing: 0.02em;
    opacity: 0.8;
  }

  .product-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr;
    gap: 64px;
    align-items: start;
  }

  .product-image {
    position: relative;
    background: var(--panel-bg);
    border: 1px solid var(--border);
    padding: 12px; /* Inner frame padding */
  }

  .product-image img {
    display: block;
    width: 100%;
    height: auto;
    filter: contrast(1.05);
    transition: filter 0.5s ease;
  }
  
  .product-image:hover img {
    filter: contrast(1.05);
  }

  .product-features {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding-top: 24px;
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .feature-content h4 {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
    color: var(--fg);
    letter-spacing: -0.01em;
  }

  .feature-content p {
    margin: 0;
    font-size: 15px;
    color: var(--muted);
    line-height: 1.6;
  }

  .features-link {
    display: inline-block;
    color: var(--fg);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    margin-top: 16px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2px;
    align-self: flex-start;
    transition: all 0.2s;
  }

  .features-link:hover {
    color: #fff;
    border-color: #fff;
  }

  .team-grid {
    max-width: 980px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 96px;
  }

  .founder-card {
    background: transparent; /* Removed panel bg */
    padding: 0; /* Removed padding */
  }

  .founder-content {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 64px;
    align-items: start;
  }

  .founder-image {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 2px;
    overflow: hidden;
    filter: grayscale(100%);
    transition: filter 0.5s ease;
  }
  
  .founder-image:hover {
    filter: grayscale(0%);
  }

  .founder-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .founder-info {
    padding-top: 12px;
  }

  .founder-name {
    font-size: 32px;
    font-weight: 700;
    margin: 0 0 4px;
    letter-spacing: -0.03em;
    color: var(--fg);
  }

  .founder-role {
    display: block;
    font-size: 14px;
    color: var(--muted); /* Changed from accent */
    margin-bottom: 32px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
    opacity: 0.8;
  }

  .founder-bio {
    text-align: left;
  }

  .founder-bio p {
    font-size: 16px;
    color: var(--fg);
    line-height: 1.7;
    margin: 0 0 18px;
  }

  .founder-bio p:last-child {
    margin-bottom: 0;
  }

  .founder-links {
    margin-top: 24px;
    display: flex;
    gap: 16px;
    align-items: center;
    justify-content: flex-start;
  }

  .linkedin-link {
    display: inline-block;
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s;
    border-bottom: 1px solid transparent;
  }

  .linkedin-link:hover {
    color: #fff;
    border-bottom-color: #fff;
  }

  .contact-section {
    padding-bottom: 160px;
  }

  .contact-card {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    padding: 0;
    background: transparent;
    border: none;
  }

  .contact-title {
    font-size: clamp(32px, 5vw, 48px);
    margin: 0 0 24px;
    letter-spacing: -0.03em;
    font-weight: 700;
  }

  .contact-text {
    font-size: 18px;
    color: var(--muted);
    margin: 0 0 48px;
    line-height: 1.6;
  }

  .contact-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
    font-size: 18px;
  }

  .text-link {
    color: var(--fg);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }
  
  .text-link:hover {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  
  .separator {
    color: var(--border);
  }

  @media (max-width: 900px) {
    .mission-grid,
    .solution-grid,
    .product-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    
    .product-grid {
      display: flex;
      flex-direction: column-reverse;
    }

    .founder-content {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .founder-image {
      width: 200px;
      margin: 0 auto;
    }
    
    .founder-info {
      text-align: center;
    }

    .founder-bio {
      text-align: left;
    }
  }

  @media (max-width: 768px) {
    .about-hero {
      padding: 140px 24px 80px;
    }

    .about-section {
      padding: 64px 24px;
    }

    .mission-visual,
    .solution-visual {
      padding: 32px;
    }

    .product-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
    
    .contact-actions {
      flex-direction: column;
      gap: 12px;
    }
    
    .founder-links {
      flex-direction: column;
      gap: 20px;
      align-items: center;
    }
    
    .separator { display: none; }
  }
</style>
