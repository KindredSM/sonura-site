---

<section class:list={['demo', { flush }]} aria-labelledby="demo-title">
  <div class="demo-inner">
    <div class="demo-header">
      <div class="demo-header-content">
        <p class="section-kicker">{kicker}</p>
        <h2 id="demo-title" class="demo-title">{title}</h2>
        <p class="demo-subtitle">{subtitle}</p>
      </div>
    </div>
    <div class="demo-toggle" role="tablist" aria-label="Preview type">
      {demoTabs.map((tab, tabIndex) => (
        <button
          class="demo-toggle-btn"
          type="button"
          role="tab"
          id={`demo-tab-${tab.id}`}
          aria-selected={tabIndex === 0 ? 'true' : 'false'}
          aria-controls={`demo-panel-${tab.id}`}
          data-demo-tab={tab.id}
        >{tab.label}</button>
      ))}
    </div>
    {demoTabs.map((tab, tabIndex) => (
      <div
        class="demo-tracks-list"
        id={`demo-panel-${tab.id}`}
        role="tabpanel"
        aria-labelledby={`demo-tab-${tab.id}`}
        data-demo-group={tab.id}
        hidden={tabIndex !== 0}
      >
        {tab.tracks.map((track, index) => (
          <div class={tabIndex === 0 ? 'demo-track reveal' : 'demo-track'} data-reveal-delay={`${index * 0.05}s`}>
            <button
              class="demo-play"
              type="button"
              data-demo-audio={track.src}
              aria-label={`Play ${track.title}`}
            >
              <svg class="demo-icon-play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7 4l14 8-14 8V4z"/></svg>
              <svg class="demo-icon-pause" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>
            </button>
            <div class="demo-track-info">
              <span class="demo-track-title">{track.title}</span>
              <span class="demo-track-meta">{track.meta}</span>
            </div>
            <div class="demo-track-progress" role="presentation">
              <svg class="demo-wave" viewBox={`0 0 ${track.peaks.length * 3} 40`} preserveAspectRatio="none" aria-hidden="true">
                {track.peaks.map((p, i) => <rect x={i * 3} y={20 - p * 19} width={2} height={p * 38} />)}
              </svg>
              <svg class="demo-wave demo-wave-played" viewBox={`0 0 ${track.peaks.length * 3} 40`} preserveAspectRatio="none" aria-hidden="true" style="clip-path: inset(0 100% 0 0)">
                {track.peaks.map((p, i) => <rect x={i * 3} y={20 - p * 19} width={2} height={p * 38} />)}
              </svg>
            </div>
            <span class="demo-track-time" data-duration={track.duration}>{track.duration}</span>
          </div>
        ))}
      </div>
    ))}
    <a class="demo-explore" href="https://app.sonurastudio.com/samples">Explore community sounds</a>
  </div>
</section>

<style>
  /* De-scoped from body.editorial-home so the module works on any page.
     --rule is homepage-only (defined in home-editorial.css), so redefine it
     here; --hairline and the rest are global (global.css). */
  .demo {
    --rule: 1px solid var(--hairline);
    border-top: var(--rule);
    padding: clamp(72px, 9vw, 110px) var(--page-pad);
  }
  /* When the parent already applies the page gutter (e.g. AlternativeLayout),
     drop our own horizontal padding to avoid double-insetting. */
  .demo.flush {
    padding-left: 0;
    padding-right: 0;
  }
  .demo-inner { max-width: none; }
  .demo-header { margin-bottom: 48px; text-align: left; }
  .demo-title {
    margin: 0 0 18px;
    text-align: left;
    text-transform: uppercase;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(38px, 4.8vw, 68px);
    line-height: 1;
    letter-spacing: 0.01em;
    color: var(--fg);
  }
  .demo-subtitle {
    font-size: 14px;
    color: var(--muted);
    text-transform: lowercase;
    letter-spacing: 0.022em;
    line-height: 1.8;
    word-spacing: 0.04em;
  }
  .demo-toggle {
    display: flex;
    gap: 32px;
    margin-bottom: 24px;
  }
  .demo-toggle-btn {
    padding: 0 0 7px;
    background: none;
    border: none;
    font-family: inherit;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .demo-toggle-btn:hover { color: var(--fg); }
  .demo-toggle-btn[aria-selected='true'] {
    color: var(--fg);
    border-bottom-color: currentColor;
  }
  .demo-tracks-list {
    display: flex;
    flex-direction: column;
  }
  /* display: flex above would otherwise override the hidden attribute */
  .demo-tracks-list[hidden] { display: none; }
  .demo-track {
    display: grid;
    grid-template-columns: 56px minmax(0, 300px) 1fr 60px;
    gap: clamp(20px, 3vw, 48px);
    align-items: center;
    border-top: var(--rule);
    padding: clamp(24px, 3vw, 36px) 0;
  }
  .demo-track:last-child { border-bottom: var(--rule); }
  .demo-play {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    padding: 0;
    background: transparent;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-ui);
    color: var(--fg);
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
  }
  .demo-play:hover { border-color: var(--fg); }
  .demo-play svg { width: 18px; height: 18px; }
  .demo-play .demo-icon-pause { display: none; }
  .demo-track.is-playing .demo-icon-play { display: none; }
  .demo-track.is-playing .demo-icon-pause { display: block; }
  .demo-track.is-playing .demo-play {
    background: var(--fg);
    border-color: var(--fg);
    color: var(--bg);
  }
  .demo-track-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .demo-track-title {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg);
  }
  .demo-track-meta {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .demo-track-progress {
    position: relative;
    height: 56px;
    cursor: pointer;
  }
  .demo-wave {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  .demo-wave rect { fill: var(--border-light); }
  .demo-wave-played rect { fill: var(--fg); }
  .demo-track-time {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  .demo-explore {
    display: block;
    width: fit-content;
    margin: 56px auto 0;
    text-align: center;
    font-size: 12px;
    font-weight: 600;
