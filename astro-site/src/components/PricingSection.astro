---
interface Props {
  showHeader?: boolean;
  showTrust?: boolean;
  showSecureBadge?: boolean;
}

const { 
  showHeader = true, 
  showTrust = false,
  showSecureBadge = true 
} = Astro.props;
---

<div class="pricing-section-wrapper">
  {showHeader && (
    <div class="pricing-header-section">
  
      
      {showTrust && (
        <div class="pricing-trust">
          <div class="pricing-trust-item"><i data-lucide="check"></i> <span>You own 100% of music you create</span></div>
          <div class="pricing-trust-item"><i data-lucide="check"></i> <span>Release anywhere, keep all royalties</span></div>
          <div class="pricing-trust-item"><i data-lucide="check"></i> <span>No hidden fees or contracts</span></div>
        </div>
      )}
    </div>
  )}

  <section class="trial-hero">
    <div class="trial-hero-inner">
      <div class="trial-hero-copy">
        <h3 class="trial-hero-heading">Create studio-quality music with zero setup.</h3>
        <p class="trial-hero-subtext">Try Sonura Pro starting at $5/month.</p>
      </div>
      <div class="trial-card">
        <div class="trial-badge">trial promo</div>
        <p class="trial-plan">Pro</p>
        <div class="trial-price-row">
          <span class="trial-price">$5</span>
          <span class="trial-period">/mo for 1 month</span>
        </div>
        <p class="trial-after">$20/mo after</p>
        <button class="button primary full-width trial-button" data-plan="pro" data-trial="true">
          <span>Try Sonura for $5</span>
          <svg style="width: 16px; height: 16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </button>
      </div>
    </div>
    <div class="trial-benefits">
      <div class="trial-benefit-item">
        <span>500 monthly generation credits</span>
        <svg viewBox="0 0 20 20" fill="currentColor" class="trial-benefit-check">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
        </svg>
      </div>
      <div class="trial-benefit-item">
        <span>High quality downloads with commercial rights</span>
        <svg viewBox="0 0 20 20" fill="currentColor" class="trial-benefit-check">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
        </svg>
      </div>
      <div class="trial-benefit-item">
        <span>AI mixing and stem export</span>
        <svg viewBox="0 0 20 20" fill="currentColor" class="trial-benefit-check">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
        </svg>
      </div>
      <div class="trial-benefit-item">
        <span>Priority 24/7 support</span>
        <svg viewBox="0 0 20 20" fill="currentColor" class="trial-benefit-check">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
        </svg>
      </div>
    </div>
    <a href="#all-plans" class="view-all-link">
      <span>View all plans</span>
      <svg viewBox="0 0 20 20" fill="currentColor" class="view-all-icon" aria-hidden="true">
        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
      </svg>
    </a>
  </section>

  <div class="billing-toggle" id="all-plans">
    <button type="button" class="billing-btn active" data-interval="month">
      Monthly
    </button>
    <button type="button" class="billing-btn" data-interval="year">
      Annual
      <span class="savings-badge">Save 20%</span>
    </button>
  </div>

  <div class="pricing-grid">
    <div class="pricing-card">
      <div class="pricing-card-header">
        <h3 class="plan-name">Starter</h3>
        <div class="price-row">
          <span class="price-strikethrough">$20</span>
          <span class="plan-price">$<span class="price-amount" data-monthly="10" data-annual="8">10</span><span class="period">/mo</span></span>
        </div>
        <div class="monthly-equivalent" data-annual-text="Saves $24 by billing yearly" style="display: none;"></div>
        <p class="plan-desc">For hobbyists and beginners.</p>
      </div>

      <ul class="plan-features">
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>200 Generations / mo</span>
        </li>
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>Commercial Rights</span>
        </li>
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>Stem Export</span>
        </li>
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>AI Mixing</span>
        </li>
      </ul>

      <div class="pricing-cta">
        <button class="button secondary full-width" data-plan="starter">
          <span>Get Started</span>
          <svg style="width: 16px; height: 16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </button>
      </div>
    </div>

    <div class="pricing-card featured">
      <div class="popular-badge">Most Popular</div>
      <div class="pricing-card-header">
        <div class="plan-name-row">
          <h3 class="plan-name">Pro</h3>
          <span class="trial-offer-badge" data-trial-offer>trial offer</span>
        </div>
        <div class="price-row" data-pro-monthly-row>
          <span class="price-strikethrough">$40</span>
          <span class="plan-price">$5<span class="period">/mo for 1 month</span></span>
        </div>
        <div class="trial-regular-price" data-pro-monthly-after>$20/mo after</div>
        <div class="price-row" data-pro-yearly-row style="display: none;">
          <span class="price-strikethrough">$40</span>
          <span class="plan-price">$<span class="price-amount" data-monthly="20" data-annual="15">15</span><span class="period">/mo</span></span>
        </div>
        <div class="monthly-equivalent" data-annual-text="Saves $60 by billing yearly" style="display: none;"></div>
        <p class="plan-desc">For independent artists.</p>
      </div>

      <ul class="plan-features">
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>500 Generations / mo</span>
        </li>
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>High Quality Downloads</span>
        </li>
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>Commercial Rights</span>
        </li>
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>Stem Export</span>
        </li>
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>24/7 Support</span>
        </li>
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>AI Mixing</span>
        </li>
      </ul>

      <div class="pricing-cta">
        <button class="button primary full-width" data-plan="pro" data-trial="true">
          <span data-pro-cta-label>Try Sonura for $5</span>
          <svg style="width: 16px; height: 16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </button>
      </div>
    </div>

    <div class="pricing-card">
      <div class="pricing-card-header">
        <h3 class="plan-name">Studio</h3>
        <div class="price-row">
          <span class="price-strikethrough">$90</span>
          <span class="plan-price">$<span class="price-amount" data-monthly="45" data-annual="35">45</span><span class="period">/mo</span></span>
        </div>
        <div class="monthly-equivalent" data-annual-text="Saves $108 by billing yearly" style="display: none;"></div>
        <p class="plan-desc">For studios and professional producers.</p>
      </div>

      <ul class="plan-features">
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>Everything in Pro</span>
        </li>
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>1000 Generations / mo</span>
        </li>
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>One-to-One Support Calls</span>
        </li>
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>Early Access to New Features</span>
        </li>
        <li>
          <svg class="feature-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          <span>Custom Feature Requests</span>
        </li>
      </ul>

      <div class="pricing-cta">
        <button class="button secondary full-width" data-plan="max">
          <span>Get Started</span>
          <svg style="width: 16px; height: 16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  {showSecureBadge && (
    <div class="secure-badge">
      <svg viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
      </svg>
      <span>Secure checkout</span>
    </div>
  )}
</div>

<script>
  const currentInterval = { value: 'month' };
  const trialCouponId = 'foFKeiTs';

  document.querySelectorAll<HTMLButtonElement>('.billing-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.billing-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentInterval.value = btn.dataset.interval || 'month';
      
      document.querySelectorAll<HTMLElement>('.price-amount').forEach(amount => {
        const price = currentInterval.value === 'month' ? (amount.dataset.monthly || '') : (amount.dataset.annual || '');
        amount.textContent = price;
      });

      document.querySelectorAll<HTMLElement>('.monthly-equivalent').forEach(equiv => {
        if (currentInterval.value === 'year') {
          equiv.style.display = 'block';
          equiv.textContent = equiv.dataset.annualText || '';
        } else {
          equiv.style.display = 'none';
        }
      });

      const proMonthlyRow = document.querySelector<HTMLElement>('[data-pro-monthly-row]');
      const proMonthlyAfter = document.querySelector<HTMLElement>('[data-pro-monthly-after]');
      const proYearlyRow = document.querySelector<HTMLElement>('[data-pro-yearly-row]');
      const proCtaLabel = document.querySelector<HTMLElement>('[data-pro-cta-label]');
      const trialOfferBadge = document.querySelector<HTMLElement>('[data-trial-offer]');
      const proButtons = document.querySelectorAll<HTMLButtonElement>('button[data-plan="pro"]');

      if (currentInterval.value === 'month') {
        if (proMonthlyRow) proMonthlyRow.style.display = 'flex';
        if (proMonthlyAfter) proMonthlyAfter.style.display = 'block';
        if (proYearlyRow) proYearlyRow.style.display = 'none';
        if (proCtaLabel) proCtaLabel.textContent = 'Try Sonura for $5';
        if (trialOfferBadge) trialOfferBadge.style.display = 'inline-flex';
        proButtons.forEach(button => button.setAttribute('data-trial', 'true'));
      } else {
        if (proMonthlyRow) proMonthlyRow.style.display = 'none';
        if (proMonthlyAfter) proMonthlyAfter.style.display = 'none';
        if (proYearlyRow) proYearlyRow.style.display = 'flex';
        if (proCtaLabel) proCtaLabel.textContent = 'Get Started';
        if (trialOfferBadge) trialOfferBadge.style.display = 'none';
        proButtons.forEach(button => button.removeAttribute('data-trial'));
      }
    });
  });

  document.querySelectorAll<HTMLElement>('[data-plan]').forEach(btn => {
    btn.addEventListener('click', () => {
      const plan = btn.dataset.plan;
      const interval = currentInterval.value;
      const trial = btn.dataset.trial === 'true' && plan === 'pro' && interval === 'month';
      if (!plan) return;
      const params = new URLSearchParams({ subscribe: plan, interval });
      if (trial) {
        params.set('trial', 'true');
        params.set('coupon', trialCouponId);
        params.set('couponId', trialCouponId);
      }
      window.location.href = `https://app.sonurastudio.com?${params.toString()}`;
    });
  });
</script>

<style>
  .pricing-section-wrapper {
    width: 100%;
  }

  .trial-hero {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto 48px;
    background: transparent;
  }

  .trial-hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 64px;
    padding: 20px 0;
  }

  .trial-hero-copy {
    flex: 1;
    text-align: left;
  }

  .trial-hero-heading {
    margin: 0;
    font-size: clamp(32px, 4.5vw, 48px);
    letter-spacing: -0.035em;
    line-height: 1.08;
  }

  .trial-hero-subtext {
    margin: 16px 0 0;
    color: rgba(255, 255, 255, 0.6);
    font-size: 18px;
    line-height: 1.5;
  }

  .trial-card {
    width: 380px;
    flex-shrink: 0;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.03);
    padding: 28px;
    text-align: left;
  }

  .trial-badge {
    display: inline-flex;
    align-items: center;
    padding: 5px 12px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.05);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 16px;
  }

  .trial-plan {
    margin: 0;
    font-size: 18px;
    font-weight: 700;
  }

  .trial-price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-top: 4px;
  }

  .trial-price {
    font-size: 52px;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .trial-period {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.55);
  }

  .trial-after {
    margin: 8px 0 20px;
    color: rgba(255, 255, 255, 0.45);
    font-size: 14px;
  }

  .trial-button {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-align: center;
  }

  .trial-benefits {
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    max-width: 100%;
    margin: 0;
    padding: 8px 0 0;
  }

  .trial-benefit-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 15px;
    color: rgba(255, 255, 255, 0.8);
  }

  .trial-benefit-item:last-child {
    border-bottom: none;
  }

  .trial-benefit-check {
    width: 18px;
    height: 18px;
    color: #10b981;
    flex-shrink: 0;
  }

  .view-all-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin: 28px auto 12px;
    width: 100%;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.2);
    text-underline-offset: 4px;
    font-size: 13px;
    font-weight: 500;
    line-height: 1;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  .view-all-link:hover {
    color: rgba(255, 255, 255, 0.85);
    text-decoration-color: rgba(255, 255, 255, 0.5);
  }

  .view-all-icon {
    width: 14px;
    height: 14px;
    display: block;
    transform: translateY(0.5px);
  }

  .pricing-header-section {
    text-align: center;
    margin-bottom: 56px;
  }

  .pricing-title {
    font-size: 48px;
    font-weight: 800;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .pricing-subtitle {
    font-size: 20px;
    color: var(--muted);
    margin: 0 auto;
    line-height: 1.6;
  }

  .pricing-trust {
    display: flex;
    justify-content: center;
    gap: 32px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .pricing-trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--muted);
  }

  .pricing-trust-item i {
    color: var(--primary);
    width: 18px;
    height: 18px;
  }

  .billing-toggle {
    display: flex;
    gap: 4px;
    margin-bottom: 56px;
    padding: 5px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
  }

  .billing-btn {
    padding: 14px 32px;
    border-radius: 10px;
