---
import BaseLayout from './BaseLayout.astro';

interface Feature {
  title: string;
  description: string;
}

interface UseCase {
  title: string;
  description: string;
}

interface FAQ {
  question: string;
  answer: string;
}

interface RelatedTool {
  title: string;
  href: string;
  description: string;
}

interface RelatedBlogPost {
  title: string;
  href: string;
}

interface Props {
  toolName: string;
  toolSlug: string;
  title: string;
  description: string;
  keywords: string;
  headline?: string;
  subhead: string;
  features: Feature[];
  howItWorksTitle: string;
  howItWorksSteps: string[];
  useCases: UseCase[];
  faqs: FAQ[];
  appUrl?: string;
  ctaPrimaryText?: string;
  trustPills?: string[];
  finalCtaTitle?: string;
  finalCtaButtonText?: string;
  relatedTools?: RelatedTool[];
  relatedBlogPosts?: RelatedBlogPost[];
}

const {
  toolName,
  toolSlug,
  title,
  description,
  keywords,
  headline,
  subhead,
  features,
  howItWorksTitle,
  howItWorksSteps,
  useCases,
  faqs,
  appUrl = 'https://app.sonurastudio.com/',
  ctaPrimaryText = 'Try it free',
  trustPills = ['free to start', 'no credit card', 'commercial rights'],
  finalCtaTitle,
  finalCtaButtonText,
  relatedTools = [],
  relatedBlogPosts = [],
} = Astro.props;

const displayHeadline = headline ?? toolName;
const canonical = `https://sonurastudio.com/tools/${toolSlug}/`;

/* Numbered section kickers — related tools / blog sections are conditional,
   so numbers are assigned lazily in render order. */
let sectionNum = 0;
const kicker = (label: string) => `${String(++sectionNum).padStart(2, '0')} / ${label}`;
const stripHtml = (value: string) => value.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: `${toolName} | Sonura`,
    url: canonical,
    applicationCategory: 'MusicApplication',
    operatingSystem: 'Web Browser',
    description,
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://sonurastudio.com/' },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://sonurastudio.com/tools/' },
      { '@type': 'ListItem', position: 3, name: toolName, item: canonical },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: stripHtml(faq.answer) },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: howItWorksTitle,
    step: howItWorksSteps.map((step, index) => ({
      '@type': 'HowToStep',
      position: index + 1,
      text: step,
    })),
  },
];
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonical={canonical}
  ogTitle={title}
  ogDescription={description}
  jsonLd={jsonLd}
  bodyClass="tool-page"
>
  <style>
    .tp-hero {
      padding: clamp(56px, 9vh, 110px) var(--page-pad) clamp(72px, 9vw, 110px);
      text-align: left;
    }

    .tp-h1 {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(48px, 7vw, 104px);
      line-height: 0.98;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      margin: 0 0 28px;
      color: var(--fg);
    }

    .tp-sub {
      margin: 0 0 44px;
      font-size: 17px;
      color: var(--muted);
      max-width: 560px;
      text-transform: lowercase;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      line-height: 1.8;
    }

    .tp-cta-row {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .tp-cta-btn {
      display: inline-block;
      padding: 20px 36px;
      background: var(--fg);
      border: 1px solid var(--fg);
      color: var(--bg);
      text-decoration: none;
      border-radius: var(--radius-ui);
      font-weight: 600;
      font-size: 13px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      line-height: 1.2;
    }

    .tp-pills {
      display: flex;
      gap: 0;
      row-gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-start;
      align-items: baseline;
    }
    .tp-pill {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .tp-pill:not(:first-child)::before {
      content: '/';
      margin: 0 14px;
      color: var(--faint);
    }

    .tp-section {
      border-top: 1px solid var(--hairline);
      padding: clamp(72px, 9vw, 110px) var(--page-pad);
    }
    .tp-section.alt {
      background: transparent;
    }
    .tp-section-inner {
      max-width: none;
      margin: 0;
    }
    .tp-section-title {
      margin: 0 0 48px;
      text-align: left;
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(38px, 4.8vw, 68px);
      letter-spacing: 0.01em;
      line-height: 1;
      text-transform: uppercase;
      color: var(--fg);
    }

    .tp-features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: var(--radius-panel);
    }
    .tp-feat-card {
      padding: 32px;
      background: var(--bg);
    }
    .tp-feat-card h3 {
      margin: 0 0 12px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--fg);
    }
    .tp-feat-card p {
      margin: 0;
      font-size: 14px;
      color: var(--muted);
      text-transform: lowercase;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      line-height: 1.8;
    }
    @media (max-width: 768px) {
      .tp-features-grid {
        grid-template-columns: 1fr;
      }
    }

    .tp-steps {
      display: flex;
      flex-direction: column;
      gap: 0;
      max-width: 640px;
      margin: 0;
    }
    .tp-step {
      display: flex;
      align-items: center;
      gap: 20px;
    }
    .tp-step-num {
      width: 36px;
      height: 36px;
      border-radius: var(--radius-ui);
      border: 1px solid var(--border-light);
      color: var(--muted);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 500;
      font-size: 13px;
      font-variant-numeric: tabular-nums;
      flex-shrink: 0;
    }
    .tp-step-text {
      margin: 0;
      font-size: 15px;
      text-transform: lowercase;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      line-height: 1.8;
      color: var(--fg);
    }
    .tp-step-line {
      width: 1px;
      height: 24px;
      background: var(--border);
      margin-left: 17px;
    }

    .tp-usecases-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
    .tp-uc-card {
      padding: 28px;
      border: 1px solid var(--border-light);
      border-radius: var(--radius-panel);
    }
    .tp-uc-card h3 {
      margin: 0 0 10px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--fg);
    }
    .tp-uc-card p {
      margin: 0;
      font-size: 14px;
      color: var(--muted);
      text-transform: lowercase;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      line-height: 1.8;
    }
    @media (max-width: 640px) {
      .tp-usecases-grid {
        grid-template-columns: 1fr;
      }
    }

    .tp-mid-cta {
      text-align: left;
      border-top: 1px solid var(--hairline);
      padding: clamp(72px, 9vw, 110px) var(--page-pad);
    }
    .tp-mid-cta p {
      margin: 0 0 32px;
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(24px, 2.8vw, 38px);
      letter-spacing: 0.01em;
      line-height: 1;
      text-transform: uppercase;
      color: var(--fg);
    }

    .tp-related-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .tp-rel-card {
      display: block;
      padding: 24px;
      border: 1px solid var(--border-light);
      border-radius: var(--radius-panel);
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s;
    }
    .tp-rel-card:hover {
      border-color: var(--hairline);
    }
    .tp-rel-card h3 {
      margin: 0 0 8px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--fg);
    }
    .tp-rel-card p {
      margin: 0;
      font-size: 13px;
      color: var(--muted);
      text-transform: lowercase;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      line-height: 1.8;
    }
    @media (max-width: 768px) {
      .tp-related-grid {
        grid-template-columns: 1fr;
      }
    }

    .tp-blog-list {
      max-width: 760px;
      margin: 0;
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
      border-bottom: 1px solid var(--hairline);
    }
    .tp-blog-list a {
      display: block;
      padding: 18px 0;
      border-top: 1px solid var(--hairline);
      border-radius: var(--radius-ui);
      text-decoration: none;
      color: var(--fg);
      font-weight: 600;
      font-size: 13px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      line-height: 1.5;
      transition: color 0.2s;
    }
    .tp-blog-list a:hover {
      color: var(--muted);
    }

    .tp-money-links {
      display: block;
      counter-reset: money-link;
      border-bottom: 1px solid var(--hairline);
    }
    .tp-money-link {
      counter-increment: money-link;
      display: grid;
      grid-template-columns: 64px minmax(0, 300px) 1fr;
      gap: 24px;
      align-items: baseline;
      padding: 22px 0;
      border-top: 1px solid var(--hairline);
      border-radius: var(--radius-ui);
      color: var(--fg);
      text-decoration: none;
      background: transparent;
    }
    .tp-money-link::before {
      content: counter(money-link, decimal-leading-zero);
      font-size: 13px;
      font-variant-numeric: tabular-nums;
      color: var(--faint);
    }
    .tp-money-link strong {
      display: block;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      line-height: 1.4;
      color: var(--fg);
    }
    .tp-money-link span {
      display: block;
      color: var(--muted);
      font-size: 14px;
      text-transform: lowercase;
      letter-spacing: 0.022em;
      word-spacing: 0.04em;
      line-height: 1.8;
      transition: color 0.2s;
    }
    .tp-money-link:hover span {
      color: var(--fg);
    }
    @media (max-width: 768px) {
      .tp-money-link {
        grid-template-columns: 40px 1fr;
        gap: 8px 16px;
      }
      .tp-money-link span {
        grid-column: 2;
      }
    }
  </style>

  <div class="tp-hero">
    <h1 class="tp-h1">{displayHeadline}</h1>
    <p class="tp-sub">{subhead}</p>
    <div class="tp-cta-row">
      <a href={appUrl} class="tp-cta-btn">{ctaPrimaryText}</a>
      <div class="tp-pills">
        {trustPills.map((pill) => (
          <span class="tp-pill">{pill}</span>
        ))}
      </div>
    </div>
  </div>

  <section class="tp-section">
    <div class="tp-section-inner">
      <p class="section-kicker">{kicker('Features')}</p>
      <div class="tp-features-grid">
        {features.map((feat) => (
          <div class="tp-feat-card">
            <h3>{feat.title}</h3>
            <p set:html={feat.description}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="tp-section alt">
    <div class="tp-section-inner">
      <p class="section-kicker">{kicker('How it works')}</p>
      <h2 class="tp-section-title">{howItWorksTitle}</h2>
      <div class="tp-steps">
        {howItWorksSteps.map((step, index) => (
          <Fragment>
            <div class="tp-step">
              <div class="tp-step-num">{index + 1}</div>
              <p class="tp-step-text">{step}</p>
            </div>
            {index < howItWorksSteps.length - 1 && (
              <div class="tp-step-line" />
            )}
          </Fragment>
        ))}
      </div>
    </div>
  </section>

  <div class="tp-mid-cta">
    <p>Ready to try it?</p>
    <a href={appUrl} class="tp-cta-btn">{ctaPrimaryText}</a>
  </div>

  <section class="tp-section alt" aria-labelledby="tool-paid-path-title">
    <div class="tp-section-inner">
      <p class="section-kicker">{kicker('Next steps')}</p>
      <h2 id="tool-paid-path-title" class="tp-section-title">Built for release-ready workflows</h2>
      <div class="tp-money-links">
        <a class="tp-money-link" href="/pricing/">
          <strong>Plans and credits</strong>
          <span>Compare paid plans for high-quality downloads and commercial work.</span>
        </a>
        <a class="tp-money-link" href="/plugin/">
          <strong>DAW plugin</strong>
          <span>Generate sounds inside Ableton, Logic Pro, FL Studio, and more.</span>
        </a>
        <a class="tp-money-link" href="/features/stem-export/">
          <strong>Stem export</strong>
          <span>Export drums, bass, melody, vocals, and FX for mixing.</span>
        </a>
        <a class="tp-money-link" href="/alternatives/suno-alternative/">
          <strong>vs Suno</strong>
          <span>See why producers use Sonura for stems and faster iteration.</span>
        </a>
        <a class="tp-money-link" href="/alternatives/splice-alternative/">
          <strong>vs Splice</strong>
          <span>Create original samples instead of browsing shared libraries.</span>
        </a>
      </div>
    </div>
  </section>

  <section class="tp-section">
    <div class="tp-section-inner">
      <p class="section-kicker">{kicker('Use cases')}</p>
      <h2 class="tp-section-title">Who uses this</h2>
      <div class="tp-usecases-grid">
        {useCases.map((uc) => (
          <div class="tp-uc-card">
            <h3>{uc.title}</h3>
            <p set:html={uc.description}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {relatedTools.length > 0 && (
    <section class="tp-section alt">
      <div class="tp-section-inner">
        <p class="section-kicker">{kicker('Related tools')}</p>
        <h2 class="tp-section-title">Related tools</h2>
        <div class="tp-related-grid">
          {relatedTools.map((t) => (
            <a class="tp-rel-card" href={t.href}>
              <h3>{t.title}</h3>
              <p set:html={t.description}></p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {relatedBlogPosts.length > 0 && (
    <section class="tp-section">
      <div class="tp-section-inner">
        <p class="section-kicker">{kicker('Blog')}</p>
        <h2 class="tp-section-title">From the blog</h2>
        <ul class="tp-blog-list">
          {relatedBlogPosts.map((post) => (
            <li>
              <a href={post.href}>{post.title}</a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="faq" id="faq" aria-labelledby="tool-faq-title">
    <div class="faq-inner">
      <p class="section-kicker">{kicker('FAQ')}</p>
      <h2 id="tool-faq-title" class="faq-title">{toolName} FAQ</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p set:html={faq.answer}></p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="final-cta" aria-labelledby="tool-final-cta-title">
    <div class="final-cta-inner">
      <h2 id="tool-final-cta-title" class="final-cta-title">{finalCtaTitle ?? `Start using ${toolName.toLowerCase()}`}</h2>
      <p class="final-cta-subtitle">free to start. no credit card required.</p>
      <div class="final-cta-form">
        <a class="button primary large" href={appUrl}>{finalCtaButtonText ?? 'Try it free'}</a>
        <a class="button secondary large" href="/plugin/"><span class="btn-label-full">Make sounds inside your DAW</span><span class="btn-label-short">Get the plugin</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
