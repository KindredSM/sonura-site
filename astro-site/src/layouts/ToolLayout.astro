---
import BaseLayout from './BaseLayout.astro';

interface Feature {
  title: string;
  description: string;
}

interface UseCase {
  title: string;
  description: string;
}

interface FAQ {
  question: string;
  answer: string;
}

interface RelatedTool {
  title: string;
  href: string;
  description: string;
}

interface RelatedBlogPost {
  title: string;
  href: string;
}

interface Props {
  toolName: string;
  toolSlug: string;
  title: string;
  description: string;
  keywords: string;
  headline?: string;
  subhead: string;
  features: Feature[];
  howItWorksTitle: string;
  howItWorksSteps: string[];
  useCases: UseCase[];
  faqs: FAQ[];
  appUrl?: string;
  ctaPrimaryText?: string;
  trustPills?: string[];
  finalCtaTitle?: string;
  finalCtaButtonText?: string;
  relatedTools?: RelatedTool[];
  relatedBlogPosts?: RelatedBlogPost[];
}

const {
  toolName,
  toolSlug,
  title,
  description,
  keywords,
  headline,
  subhead,
  features,
  howItWorksTitle,
  howItWorksSteps,
  useCases,
  faqs,
  appUrl = 'https://app.sonurastudio.com/studio',
  ctaPrimaryText = 'Try it free',
  trustPills = ['free to start', 'no credit card', 'commercial rights'],
  finalCtaTitle,
  finalCtaButtonText,
  relatedTools = [],
  relatedBlogPosts = [],
} = Astro.props;

const displayHeadline = headline ?? toolName;
const canonical = `https://sonurastudio.com/tools/${toolSlug}/`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: `${toolName} — Sonura`,
    url: canonical,
    applicationCategory: 'MusicApplication',
    operatingSystem: 'Web Browser',
    description,
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://sonurastudio.com/' },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://sonurastudio.com/tools/' },
      { '@type': 'ListItem', position: 3, name: toolName, item: canonical },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: howItWorksTitle,
    step: howItWorksSteps.map((step, index) => ({
      '@type': 'HowToStep',
      position: index + 1,
      text: step,
    })),
  },
];
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonical={canonical}
  ogTitle={title}
  ogDescription={description}
  jsonLd={jsonLd}
  bodyClass="tool-page"
>
  <style>
    .tp-hero {
      padding: 160px 24px 100px;
      text-align: center;
      max-width: 820px;
      margin: 0 auto;
    }

    .tp-h1 {
      font-size: clamp(38px, 6vw, 64px);
      line-height: 1.08;
      margin: 0 0 24px;
      letter-spacing: -0.03em;
      font-weight: 700;
      color: var(--fg);
    }

    .tp-sub {
      margin: 0 auto 44px;
      font-size: clamp(16px, 2vw, 19px);
      color: var(--muted);
      max-width: 580px;
      line-height: 1.6;
    }

    .tp-cta-row {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }

    .tp-cta-btn {
      display: inline-block;
      padding: 14px 32px;
      background: #fff;
      color: #000;
      text-decoration: none;
      border-radius: 10px;
      font-weight: 600;
      font-size: 15px;
      transition: opacity 0.2s;
    }
    .tp-cta-btn:hover {
      opacity: 0.85;
    }

    .tp-pills {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .tp-pill {
      padding: 5px 12px;
      border-radius: 999px;
      font-size: 12px;
      color: var(--muted);
      border: 1px solid var(--border);
    }

    .tp-section {
      padding: 100px 24px;
    }
    .tp-section.alt {
      background: rgba(255,255,255,0.02);
    }
    .tp-section-inner {
      max-width: 1000px;
      margin: 0 auto;
    }
    .tp-section-title {
      margin: 0 0 56px;
      text-align: center;
      font-size: clamp(24px, 3.5vw, 36px);
      letter-spacing: -0.02em;
      font-weight: 700;
      color: var(--fg);
    }

    .tp-features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
    }
    .tp-feat-card {
      padding: 32px;
      background: var(--bg);
    }
    .tp-feat-card h3 {
      margin: 0 0 10px;
      font-size: 15px;
      font-weight: 600;
      color: var(--fg);
    }
    .tp-feat-card p {
      margin: 0;
      font-size: 14px;
      color: var(--muted);
      line-height: 1.6;
    }
    @media (max-width: 768px) {
      .tp-features-grid {
        grid-template-columns: 1fr;
      }
    }

    .tp-steps {
      display: flex;
      flex-direction: column;
      gap: 0;
      max-width: 640px;
      margin: 0 auto;
    }
    .tp-step {
      display: flex;
      align-items: center;
      gap: 20px;
    }
    .tp-step-num {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1px solid var(--border);
      color: var(--muted);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 14px;
      flex-shrink: 0;
    }
    .tp-step-text {
      font-size: 16px;
      line-height: 1.6;
      color: var(--fg);
    }
    .tp-step-line {
      width: 1px;
      height: 24px;
      background: var(--border);
      margin-left: 17px;
    }

    .tp-usecases-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
    .tp-uc-card {
      padding: 28px;
      border: 1px solid var(--border);
      border-radius: 14px;
    }
    .tp-uc-card h3 {
      margin: 0 0 8px;
      font-size: 15px;
      font-weight: 600;
      color: var(--fg);
    }
    .tp-uc-card p {
      margin: 0;
      font-size: 14px;
      color: var(--muted);
      line-height: 1.6;
    }
    @media (max-width: 640px) {
      .tp-usecases-grid {
        grid-template-columns: 1fr;
      }
    }

    .tp-mid-cta {
      text-align: center;
      padding: 80px 24px;
    }
    .tp-mid-cta p {
      margin: 0 0 28px;
      font-size: clamp(18px, 2.5vw, 24px);
      font-weight: 600;
      color: var(--fg);
      letter-spacing: -0.01em;
    }

    .tp-related-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .tp-rel-card {
      display: block;
      padding: 24px;
      border: 1px solid var(--border);
      border-radius: 14px;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s;
    }
    .tp-rel-card:hover {
      border-color: var(--border-light);
    }
    .tp-rel-card h3 {
      margin: 0 0 6px;
      font-size: 15px;
      font-weight: 600;
      color: var(--fg);
    }
    .tp-rel-card p {
      margin: 0;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.5;
    }
    @media (max-width: 768px) {
      .tp-related-grid {
        grid-template-columns: 1fr;
      }
    }

    .tp-blog-list {
      max-width: 560px;
      margin: 0 auto;
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .tp-blog-list a {
      display: block;
      padding: 14px 20px;
      border: 1px solid var(--border);
      border-radius: 10px;
      text-decoration: none;
      color: var(--fg);
      font-weight: 500;
      font-size: 14px;
      transition: border-color 0.2s;
    }
    .tp-blog-list a:hover {
      border-color: var(--border-light);
    }
  </style>

  <div class="tp-hero">
    <h1 class="tp-h1">{displayHeadline}</h1>
    <p class="tp-sub">{subhead}</p>
    <div class="tp-cta-row">
      <a href={appUrl} class="tp-cta-btn">{ctaPrimaryText}</a>
      <div class="tp-pills">
        {trustPills.map((pill) => (
          <span class="tp-pill">{pill}</span>
        ))}
      </div>
    </div>
  </div>

  <section class="tp-section">
    <div class="tp-section-inner">
      <div class="tp-features-grid">
        {features.map((feat) => (
          <div class="tp-feat-card">
            <h3>{feat.title}</h3>
            <p>{feat.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="tp-section alt">
    <div class="tp-section-inner">
      <h2 class="tp-section-title">{howItWorksTitle}</h2>
      <div class="tp-steps">
        {howItWorksSteps.map((step, index) => (
          <Fragment>
            <div class="tp-step">
              <div class="tp-step-num">{index + 1}</div>
              <p class="tp-step-text">{step}</p>
            </div>
            {index < howItWorksSteps.length - 1 && (
              <div class="tp-step-line" />
            )}
          </Fragment>
        ))}
      </div>
    </div>
  </section>

  <div class="tp-mid-cta">
    <p>Ready to try it?</p>
    <a href={appUrl} class="tp-cta-btn">{ctaPrimaryText}</a>
  </div>

  <section class="tp-section">
    <div class="tp-section-inner">
      <h2 class="tp-section-title">Who uses this</h2>
      <div class="tp-usecases-grid">
        {useCases.map((uc) => (
          <div class="tp-uc-card">
            <h3>{uc.title}</h3>
            <p>{uc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {relatedTools.length > 0 && (
    <section class="tp-section alt">
      <div class="tp-section-inner">
        <h2 class="tp-section-title">Related tools</h2>
        <div class="tp-related-grid">
          {relatedTools.map((t) => (
            <a class="tp-rel-card" href={t.href}>
              <h3>{t.title}</h3>
              <p>{t.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {relatedBlogPosts.length > 0 && (
    <section class="tp-section">
      <div class="tp-section-inner">
        <h2 class="tp-section-title">From the blog</h2>
        <ul class="tp-blog-list">
          {relatedBlogPosts.map((post) => (
            <li>
              <a href={post.href}>{post.title}</a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="faq" id="faq" aria-labelledby="tool-faq-title">
    <div class="faq-inner">
      <h2 id="tool-faq-title" class="faq-title">{toolName} FAQ</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="final-cta" aria-labelledby="tool-final-cta-title">
    <div class="final-cta-inner">
      <h2 id="tool-final-cta-title" class="final-cta-title">{finalCtaTitle ?? `Start using ${toolName.toLowerCase()}`}</h2>
      <p class="final-cta-subtitle">free to start. no credit card required.</p>
      <div class="final-cta-form">
        <a class="button primary large" href={appUrl}>{finalCtaButtonText ?? 'Try it free'}</a>
      </div>
    </div>
  </section>
</BaseLayout>
