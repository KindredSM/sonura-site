---
import BaseLayout from './BaseLayout.astro';

interface GuideSection {
  title: string;
  body: string;
  bullets?: string[];
}

interface GuideLink {
  title: string;
  href: string;
  description: string;
}

interface Faq {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  keywords: string;
  slug: string;
  headline: string;
  subhead: string;
  format: string;
  bestFor: string;
  steps: string[];
  sections: GuideSection[];
  faqs: Faq[];
  relatedGuides?: GuideLink[];
  ctaText?: string;
}

const {
  title,
  description,
  keywords,
  slug,
  headline,
  subhead,
  format,
  bestFor,
  steps,
  sections,
  faqs,
  relatedGuides = [],
  ctaText = 'Download the plugin',
} = Astro.props;

const canonical = `https://sonurastudio.com/plugin/${slug}/`;
const stripHtml = (value: string) => value.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    "headline": headline,
    "description": description,
    "author": { "@type": "Organization", "name": "Sonura" },
    "publisher": {
      "@type": "Organization",
      "name": "Sonura",
      "logo": { "@type": "ImageObject", "url": "https://sonurastudio.com/demo-image.jpeg" }
    },
    "mainEntityOfPage": canonical,
    "image": "https://sonurastudio.com/images/plugin-ui.webp"
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": headline,
    "description": description,
    "step": steps.map((step, index) => ({
      "@type": "HowToStep",
      "position": index + 1,
      "text": step
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sonurastudio.com/" },
      { "@type": "ListItem", "position": 2, "name": "Plugin", "item": "https://sonurastudio.com/plugin/" },
      { "@type": "ListItem", "position": 3, "name": headline, "item": canonical }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((faq) => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": stripHtml(faq.answer)
      }
    }))
  }
];
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonical={canonical}
  ogTitle={headline}
  ogDescription={description}
  jsonLd={jsonLd}
>
  <article class="pg-guide">
    <header class="guide-hero">
      <a class="back-link" href="/plugin/">Plugin home</a>
      <p class="guide-kicker">{format}</p>
      <h1>{headline}</h1>
      <p>{subhead}</p>
      <div class="guide-actions">
        <a class="button primary" href="/plugin/">{ctaText}</a>
        <a class="button secondary" href="#setup">View setup steps</a>
      </div>
    </header>

    <section class="guide-summary" aria-label="Plugin guide summary">
      <div>
        <span>Plugin format</span>
        <strong>{format}</strong>
      </div>
      <div>
        <span>Best for</span>
        <strong>{bestFor}</strong>
      </div>
      <div>
        <span>Cost</span>
        <strong>Free download + starter credits</strong>
      </div>
    </section>

    <section class="guide-split" id="setup" aria-labelledby="setup-title">
      <div>
        <p class="guide-kicker">Setup</p>
        <h2 id="setup-title">How to use the plugin here</h2>
        <p>These are the practical first-session steps. Install the plugin, let your DAW scan it, then generate royalty-free audio without leaving the project.</p>
      </div>
      <ol class="step-list">
        {steps.map((step) => <li>{step}</li>)}
      </ol>
    </section>

    <section class="section-stack">
      {sections.map((section) => (
        <section class="guide-section">
          <h2>{section.title}</h2>
          <p set:html={section.body}></p>
          {section.bullets && (
            <ul>
              {section.bullets.map((bullet) => <li set:html={bullet}></li>)}
            </ul>
          )}
        </section>
      ))}
    </section>

    <section class="guide-faq" aria-labelledby="guide-faq-title">
      <h2 id="guide-faq-title">FAQ</h2>
      <div>
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p set:html={faq.answer}></p>
          </details>
        ))}
      </div>
    </section>

    {relatedGuides.length > 0 && (
      <section class="related-guides" aria-labelledby="related-guides-title">
        <h2 id="related-guides-title">Related plugin guides</h2>
        <div>
          {relatedGuides.map((guide) => (
            <a href={guide.href}>
              <strong>{guide.title}</strong>
              <span>{guide.description}</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .pg-guide {
    width: 100%;
    padding: clamp(56px, 9vh, 110px) var(--page-pad) clamp(96px, 12vw, 140px);
    color: var(--fg);
  }

  .guide-hero {
    max-width: 900px;
    margin-bottom: clamp(48px, 7vw, 80px);
  }

  .back-link,
  .guide-kicker {
    display: inline-flex;
    color: var(--muted);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .back-link {
    margin-bottom: 24px;
  }

  .back-link:hover {
    color: var(--fg);
  }

  .guide-hero h1 {
    margin: 14px 0 22px;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(42px, 7vw, 96px);
    line-height: 0.98;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--fg);
  }

  .guide-split p,
  .guide-section p,
  .guide-section li,
  .step-list li {
    color: var(--muted);
    text-transform: lowercase;
    letter-spacing: 0.022em;
    line-height: 1.8;
    font-size: 16px;
  }

  .guide-hero > p {
    margin: 0;
    max-width: 640px;
    color: var(--muted);
    font-size: 16px;
    text-transform: lowercase;
    letter-spacing: 0.022em;
    word-spacing: 0.04em;
    line-height: 1.8;
  }

  .guide-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .guide-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: clamp(56px, 8vw, 96px);
  }

  .guide-summary div {
    border: 1px solid var(--border-light);
    border-radius: var(--radius-panel);
    padding: 22px 18px;
    background: transparent;
  }

  .guide-summary span {
    display: block;
    color: var(--muted);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .guide-summary strong {
    display: block;
    line-height: 1.35;
  }

  .guide-split {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 48px;
    align-items: start;
    border-top: 1px solid var(--hairline);
    padding-top: clamp(48px, 7vw, 80px);
    margin-bottom: clamp(56px, 8vw, 96px);
  }

  .guide-split h2,
  .guide-section h2,
  .guide-faq h2,
  .related-guides h2 {
    margin: 12px 0 18px;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(28px, 4vw, 52px);
    line-height: 1;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--fg);
  }

  .step-list {
    margin: 0;
    padding-left: 24px;
  }

  .step-list li + li {
    margin-top: 12px;
  }

  .section-stack {
    display: grid;
    gap: 0;
    margin-bottom: clamp(56px, 8vw, 96px);
  }

  .guide-section {
    max-width: 820px;
    border-top: 1px solid var(--hairline);
    padding: 40px 0;
  }

  .guide-section:last-child {
    padding-bottom: 0;
  }

  .guide-section ul {
    margin: 18px 0 0;
    padding-left: 22px;
  }

  .guide-section li + li {
    margin-top: 8px;
  }

  .guide-faq {
    border-top: 1px solid var(--hairline);
    padding-top: clamp(48px, 7vw, 80px);
    margin-bottom: clamp(56px, 8vw, 96px);
  }

  .guide-faq > div {
    border-bottom: 1px solid var(--hairline);
  }

  .guide-faq details {
    border: 0;
    border-top: 1px solid var(--hairline);
    border-radius: 0;
    padding: 0;
    background: transparent;
  }

  .guide-faq summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    padding: 22px 0;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg);
  }

  .guide-faq summary::-webkit-details-marker {
    display: none;
  }

  .guide-faq summary::after {
    content: '+';
    font-size: 22px;
    line-height: 1;
    color: var(--faint);
    flex-shrink: 0;
  }

  .guide-faq details[open] summary::after {
    content: '\2212';
  }

  .guide-faq p {
    margin: 0;
    padding: 0 0 24px;
    max-width: 760px;
    color: var(--muted);
    font-size: 15px;
    text-transform: lowercase;
    letter-spacing: 0.022em;
    word-spacing: 0.04em;
    line-height: 1.8;
  }

  .related-guides {
    border-top: 1px solid var(--hairline);
    padding-top: clamp(48px, 7vw, 80px);
  }

  .related-guides > div {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .related-guides a {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 116px;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-panel);
    padding: 22px 18px;
    color: var(--fg);
    text-decoration: none;
    background: transparent;
  }

  .related-guides a:hover {
    border-color: var(--fg);
    background: transparent;
  }

  .related-guides strong {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .related-guides span {
    color: var(--muted);
    font-size: 13px;
    text-transform: lowercase;
    letter-spacing: 0.022em;
    line-height: 1.7;
  }

  @media (max-width: 860px) {
    .guide-summary,
    .guide-split,
    .related-guides > div {
      grid-template-columns: 1fr;
    }

    .guide-split {
      gap: 24px;
    }
  }

  @media (max-width: 640px) {
    .pg-guide {
      padding-top: 64px;
    }

    .guide-actions {
      flex-direction: column;
    }

    .guide-actions .button {
      width: 100%;
      justify-content: center;
    }
  }
</style>
